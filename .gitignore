# 物业管理系统 - Git忽略文件

# ==================== 通用忽略 ====================

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE 和编辑器
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# 临时文件
*.tmp
*.temp
*~

# 日志文件
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==================== Node.js ====================

# 依赖目录
node_modules/
jspm_packages/

# npm
.npm
.npmrc

# yarn
.yarn/
.yarn-integrity

# pnpm
.pnpm-debug.log*

# 构建输出
dist/
build/
coverage/

# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local


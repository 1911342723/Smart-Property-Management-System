<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.property.mapper.MessageMapper">

    <resultMap id="BaseResultMap" type="com.property.entity.Message">
        <id column="id" property="id" />
        <result column="title" property="title" />
        <result column="content" property="content" />
        <result column="message_type" property="messageType" />
        <result column="level" property="level" />
        <result column="sender_id" property="senderId" />
        <result column="receiver_id" property="receiverId" />
        <result column="is_read" property="isRead" />
        <result column="business_id" property="businessId" />
        <result column="business_type" property="businessType" />
        <result column="icon" property="icon" />
        <result column="icon_bg" property="iconBg" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="deleted" property="deleted" />
    </resultMap>

    <resultMap id="MessageWithSenderMap" type="com.property.entity.Message" extends="BaseResultMap">
        <result column="sender_name" property="senderName" />
    </resultMap>

    <select id="selectMessagePageWithSender" resultMap="MessageWithSenderMap">
        SELECT 
            m.*,
            u.real_name as sender_name
        FROM message m
        LEFT JOIN sys_user u ON m.sender_id = u.id
        WHERE m.deleted = 0
        AND m.receiver_id = #{receiverId}
        <if test="messageType != null and messageType != ''">
            AND m.message_type = #{messageType}
        </if>
        <if test="isRead != null">
            AND m.is_read = #{isRead}
        </if>
        ORDER BY m.create_time DESC
    </select>

    <select id="countUnreadMessages" resultType="int">
        SELECT COUNT(*)
        FROM message
        WHERE deleted = 0
        AND receiver_id = #{receiverId}
        AND is_read = 0
        <if test="messageType != null and messageType != ''">
            AND message_type = #{messageType}
        </if>
    </select>

    <update id="markMessagesAsRead">
        UPDATE message 
        SET is_read = 1, update_time = NOW()
        WHERE deleted = 0
        AND receiver_id = #{receiverId}
        AND id IN
        <foreach collection="messageIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>

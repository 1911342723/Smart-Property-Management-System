/* pages/worker/messages.wxss */
.messages-container {
  width: 100%;
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 头部 */
.header {
  width: 100%;
  background: #ffffff;
  padding: calc(var(--status-bar-height, 20px) + 24rpx) 32rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.header-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3748;
}

.unread-badge {
  background: #e53e3e;
  padding: 4rpx 12rpx;
  border-radius: 24rpx;
  min-width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-text {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

.header-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  color: #4299e1;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn:active {
  opacity: 0.6;
}

/* 标签切换 */
.tabs {
  width: 100%;
  background: #ffffff;
  display: flex;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  position: relative;
  transition: all 0.3s ease;
}

.tab-text {
  color: #718096;
  font-size: 28rpx;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: #2d3748;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2d3748;
  border-radius: 2rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  width: 100%;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

.message-item {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  gap: 24rpx;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.message-item.unread {
  background: #f7fafc;
  border-color: #4299e1;
}

.message-item:active {
  background: #edf2f7;
  transform: scale(0.98);
}

.message-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #4299e1 0%, #3182ce 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.message-icon .icon {
  width: 40rpx;
  height: 40rpx;
  filter: invert(1);
}

.message-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.message-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3748;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-time {
  font-size: 24rpx;
  color: #a0aec0;
  flex-shrink: 0;
}

.message-text {
  font-size: 26rpx;
  color: #718096;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.unread-dot {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  width: 16rpx;
  height: 16rpx;
  background: #e53e3e;
  border-radius: 50%;
}

/* 加载状态 */
.loading-more,
.no-more {
  padding: 32rpx 0;
  text-align: center;
}

.loading-text,
.no-more-text {
  color: #a0aec0;
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.3;
}

.empty-text {
  color: #a0aec0;
  font-size: 28rpx;
}

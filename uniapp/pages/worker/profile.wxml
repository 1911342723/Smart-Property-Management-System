<!--pages/worker/profile.wxml-->
<view class="profile-container">
  <!-- 用户信息头部 -->
  <view class="profile-header">
    <!-- 状态切换按钮 - 固定在右上角 -->
    <view class="floating-status-toggle" bindtap="toggleWorkStatus">
      <view class="status-indicator {{userInfo.workStatus === 'BUSY' ? 'busy' : 'available'}}"></view>
      <text class="status-text">{{userInfo.workStatus === 'BUSY' ? '忙碌' : '空闲'}}</text>
    </view>

    <view class="user-card">
      <view class="avatar-section">
        <image class="avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        <view class="camera-btn" bindtap="changeAvatar">
          <image class="camera-icon" src="/static/icons/camera.svg" mode="aspectFit"></image>
        </view>
      </view>
      
      <view class="user-info">
        <view class="user-name-section">
          <text class="user-name">{{userInfo.name}}</text>
          <view class="edit-btn" bindtap="editProfile">
            <image class="edit-icon" src="/static/icons/edit.svg" mode="aspectFit"></image>
          </view>
        </view>
        <view class="user-details">
          <text class="detail-item">工号：{{userInfo.workerId}}</text>
          <text class="detail-item">{{userInfo.phone}}</text>
        </view>
        <view class="skill-tags-section">
          <view class="section-header">
            <text class="section-title">技能标签</text>
            <view class="refresh-btn" bindtap="refreshSkillTags">
              <image class="refresh-icon" src="/static/icons/refresh.svg" mode="aspectFit"></image>
            </view>
          </view>
          <view class="skill-tags">
            <view 
              class="skill-tag"
              wx:for="{{userInfo.skillTags}}"
              wx:key="index"
              bindlongpress="removeSkillTag"
              data-index="{{index}}"
              data-tag="{{item}}"
            >
              <text class="skill-text">{{item}}</text>
            </view>
            <view class="skill-tag add-tag" bindtap="editSkillTags">
              <image class="add-icon" src="/static/icons/plus.svg" mode="aspectFit"></image>
              <text class="add-text">添加</text>
            </view>
          </view>
          <view class="skill-tags-info">
            <text class="info-text">可选择 {{availableSkillTags.length}} 种管理员设置的技能标签</text>
            <text class="hint-text">长按标签可删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 工作统计 -->
    <view class="stats-section">
      <view class="section-header">
        <text class="section-title">工作统计</text>
        <text class="section-action" bindtap="viewStatsDetail">查看详情</text>
      </view>
      
      <view class="stats-grid">
        <view class="stat-item" bindtap="viewStatsDetail">
          <text class="stat-number">{{workStats.totalOrders}}</text>
          <text class="stat-label">总工单</text>
        </view>
        <view class="stat-item" bindtap="viewStatsDetail">
          <text class="stat-number">{{workStats.completedOrders}}</text>
          <text class="stat-label">已完成</text>
        </view>
        <view class="stat-item" bindtap="viewStatsDetail">
          <text class="stat-number">{{workStats.processingOrders}}</text>
          <text class="stat-label">处理中</text>
        </view>
        <view class="stat-item" bindtap="viewStatsDetail">
          <text class="stat-number">{{workStats.averageRating}}</text>
          <text class="stat-label">平均评分</text>
        </view>
      </view>
      
      <!-- 额外统计信息 -->
      <view class="extra-stats">
        <view class="extra-stat-item">
          <image class="extra-stat-icon" src="/static/icons/calendar.svg" mode="aspectFit"></image>
          <text class="extra-stat-text">工作 {{workStats.workDays}} 天</text>
        </view>
        <view class="extra-stat-item" wx:if="{{workStats.totalIncome > 0}}">
          <image class="extra-stat-icon" src="/static/icons/credit-card.svg" mode="aspectFit"></image>
          <text class="extra-stat-text">总收入 ¥{{workStats.totalIncome}}</text>
        </view>
      </view>
    </view>


    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-list">
        <view 
          class="menu-item"
          wx:for="{{menuItems}}"
          wx:key="id"
          bindtap="onMenuItemTap"
          data-item="{{item}}"
        >
          <view class="menu-icon">
            <image class="icon" src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <text class="menu-name">{{item.name}}</text>
          <view class="menu-arrow" wx:if="{{item.arrow}}">
            <image class="arrow-icon" src="/static/icons/arrow-right.svg" mode="aspectFit"></image>
          </view>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <button class="logout-btn" bindtap="logout">
        <image class="logout-icon" src="/static/icons/logout.svg" mode="aspectFit"></image>
        <text class="logout-text">退出登录</text>
      </button>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>
</view>
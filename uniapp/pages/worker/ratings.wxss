/* pages/worker/ratings.wxss */
.ratings-container {
  min-height: 100vh;
  background: #f8f9fa;
}

.ratings-header {
  background: #ffffff;
  padding: 48rpx 32rpx;
}

.avg-rating {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.avg-value {
  font-size: 72rpx;
  font-weight: 700;
  color: #ffc107;
}

.stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 36rpx;
  color: #ffc107;
}

.total-count {
  font-size: 24rpx;
  color: #a0aec0;
}

.rating-distribution {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dist-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.dist-label {
  width: 60rpx;
  font-size: 24rpx;
  color: #718096;
}

.dist-bar {
  flex: 1;
  height: 16rpx;
  background: #e2e8f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dist-fill {
  height: 100%;
  background: #ffc107;
}

.dist-count {
  width: 60rpx;
  text-align: right;
  font-size: 24rpx;
  color: #718096;
}

.ratings-list {
  flex: 1;
  padding: 24rpx 32rpx;
}

.rating-item {
  background: #ffffff;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.rating-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.rating-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
}

.rating-date {
  font-size: 24rpx;
  color: #a0aec0;
}

.rating-stars {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 16rpx;
}

.rating-stars .star {
  font-size: 28rpx;
  color: #e2e8f0;
}

.rating-stars .star.active {
  color: #ffc107;
}

.rating-score {
  font-size: 24rpx;
  color: #718096;
  margin-left: 8rpx;
}

.rating-title {
  display: block;
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 12rpx;
}

/* 详细评分 */
.detail-scores {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin: 16rpx 0;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.score-label {
  font-size: 24rpx;
  color: #718096;
  width: 120rpx;
}

.score-stars {
  display: flex;
  gap: 4rpx;
}

.mini-star {
  font-size: 20rpx;
  color: #e2e8f0;
}

.mini-star.active {
  color: #ffc107;
}

/* 评价标签 */
.rating-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.tag {
  padding: 8rpx 16rpx;
  background: #000;
  color: #fff;
  font-size: 22rpx;
  border-radius: 16rpx;
}

/* 评价内容 */
.rating-content {
  display: block;
  font-size: 28rpx;
  color: #2d3748;
  line-height: 1.6;
  margin-top: 12rpx;
}

/* 维修工回复 */
.worker-reply {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f0fdf4;
  border-left: 4rpx solid #10b981;
  border-radius: 8rpx;
}

.reply-label {
  display: block;
  font-size: 24rpx;
  color: #059669;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.reply-content {
  display: block;
  font-size: 26rpx;
  color: #047857;
  line-height: 1.6;
}

.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  color: #a0aec0;
  font-size: 28rpx;
}

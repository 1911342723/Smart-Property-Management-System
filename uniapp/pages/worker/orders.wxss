/* pages/worker/orders.wxss */
.orders-container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

.page-header {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  padding: calc(var(--status-bar-height, 20px) + 40rpx) 32rpx 40rpx;
  border-bottom: 1rpx solid #dee2e6;
}

.page-title {
  color: #333333;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.page-subtitle {
  color: #6c757d;
  font-size: 26rpx;
}

/* 标签切换 */
.tabs-container {
  background: #ffffff;
  padding: 0 32rpx;
  display: flex;
  border-bottom: 1rpx solid #e2e8f0;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  position: relative;
  cursor: pointer;
}

.tab-item.active {
  color: #2d3748;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2d3748;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #718096;
}

.tab-item.active .tab-text {
  color: #2d3748;
}

.tab-badge {
  background: #e53e3e;
  color: #ffffff;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.badge-text {
  font-size: 20rpx;
  font-weight: 600;
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
  padding-bottom: 140rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 32rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top: 4rpx solid #2d3748;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  color: #718096;
  font-size: 28rpx;
}

/* 工单列表 */
.orders-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.order-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.order-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

/* 工单头部 */
.order-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.order-title {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.title-text {
  color: #2d3748;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.3;
}

.urgent-badge {
  background: #fed7d7;
  border: 1rpx solid #fc8181;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.urgent-text {
  color: #e53e3e;
  font-size: 22rpx;
  font-weight: 500;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.status-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
}

/* 工单内容 */
.order-content {
  margin-bottom: 24rpx;
}

.order-desc {
  color: #4a5568;
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: block;
}

.order-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
  flex-shrink: 0;
}

.meta-text {
  color: #718096;
  font-size: 24rpx;
  flex: 1;
}

/* 工单操作 */
.order-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e2e8f0;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn.contact {
  background: #f7fafc;
  color: #2d3748;
  border: 2rpx solid #e2e8f0;
}

.action-btn.contact:active {
  background: #edf2f7;
}

.action-btn.accept {
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(45, 55, 72, 0.3);
}

.action-btn.accept:active {
  background: linear-gradient(135deg, #1a202c 0%, #171923 100%);
}

.action-btn.complete {
  background: linear-gradient(135deg, #38a169 0%, #2f855a 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(56, 161, 105, 0.3);
}

.action-btn.complete:active {
  background: linear-gradient(135deg, #2f855a 0%, #276749 100%);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
}

.empty-text {
  color: #a0aec0;
  font-size: 28rpx;
  text-align: center;
}

.bottom-placeholder {
  height: 40rpx;
}
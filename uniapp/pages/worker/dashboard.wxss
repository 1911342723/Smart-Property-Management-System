/* pages/worker/dashboard.wxss */
.dashboard-container {
  min-height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
}

/* 页面头部 */
.header-section {
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  padding: calc(var(--status-bar-height, 20px) + 32rpx) 32rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
}

.user-details {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.user-role {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-item {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.action-item:active {
  background: rgba(255, 255, 255, 0.2);
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
  filter: invert(1);
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #e53e3e;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  padding: 32rpx;
  box-sizing: border-box;
  padding-bottom: 140rpx;
}

/* 通用区域样式 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  color: #2d3748;
  font-size: 32rpx;
  font-weight: 600;
}

.section-action {
  color: #2d3748;
  font-size: 28rpx;
  opacity: 0.7;
}

.section-action:active {
  opacity: 0.5;
}

/* 工作统计 */
.stats-section {
  margin-bottom: 40rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: #ffffff;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
}

.stat-item {
  text-align: center;
}

.stat-number {
  display: block;
  color: #2d3748;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  color: #718096;
  font-size: 24rpx;
}

/* 快捷操作 */
.quick-actions-section {
  margin-bottom: 40rpx;
}

.actions-single {
  display: flex;
  flex-direction: column;
}

.action-card-single {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.action-card-single:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.action-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-card-single .action-icon {
  width: 40rpx;
  height: 40rpx;
  filter: invert(1);
}

.action-card-single .action-name {
  color: #2d3748;
  font-size: 30rpx;
  font-weight: 500;
  flex: 1;
}

.action-arrow {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

/* 最近工单 */
.recent-orders-section {
  margin-bottom: 40rpx;
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.order-card:active {
  transform: translateY(-1rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.order-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-title {
  color: #2d3748;
  font-size: 28rpx;
  font-weight: 600;
  flex: 1;
}

.urgent-badge {
  background: #fed7d7;
  border: 1rpx solid #fc8181;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.urgent-text {
  color: #e53e3e;
  font-size: 22rpx;
  font-weight: 500;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.6;
}

.info-text {
  color: #718096;
  font-size: 24rpx;
  flex: 1;
}

.order-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e2e8f0;
}

.action-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn.contact {
  background: #f7fafc;
  color: #2d3748;
  border: 2rpx solid #e2e8f0;
}

.action-btn.contact:active {
  background: #edf2f7;
}

.action-btn.start {
  background: linear-gradient(135deg, #38a169 0%, #2f855a 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(56, 161, 105, 0.3);
}

.action-btn.start:active {
  background: linear-gradient(135deg, #2f855a 0%, #276749 100%);
}

.action-btn.detail {
  background: linear-gradient(135deg, #3182ce 0%, #2c5282 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(49, 130, 206, 0.3);
}

.action-btn.detail:active {
  background: linear-gradient(135deg, #2c5282 0%, #2a4365 100%);
}

.status-tag.completed {
  flex: 1;
  height: 64rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0fff4;
  color: #38a169;
  border: 2rpx solid #9ae6b4;
}

/* 系统通知 */
.notifications-section {
  margin-bottom: 40rpx;
}

.notifications-list {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
  overflow: hidden;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.notification-item:last-child {
  border-bottom: none;
}

.notification-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f7fafc;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.notification-icon .icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.notification-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notification-title {
  color: #2d3748;
  font-size: 28rpx;
  font-weight: 600;
}

.notification-text {
  color: #4a5568;
  font-size: 26rpx;
  line-height: 1.5;
}

.notification-time {
  color: #a0aec0;
  font-size: 22rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 24rpx;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  opacity: 0.3;
}

.empty-text {
  color: #a0aec0;
  font-size: 26rpx;
  text-align: center;
}

.bottom-placeholder {
  height: 40rpx;
}
<!--pages/worker/orders.wxml-->
<view class="orders-container">
  <view class="page-header">
    <text class="page-title">工单管理</text>
    <text class="page-subtitle">处理业主报修工单</text>
  </view>

  <!-- 标签切换 -->
  <view class="tabs-container">
    <view 
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >
      <text class="tab-text">{{item.name}}</text>
      <view class="tab-badge" wx:if="{{item.count > 0}}">
        <text class="badge-text">{{item.count}}</text>
      </view>
    </view>
  </view>

  <scroll-view 
    scroll-y 
    class="content" 
    refresher-enabled="{{true}}" 
    refresher-default-style="black"
    refresher-background="#f5f5f5"
    bindrefresherrefresh="onRefresh" 
    refresher-triggered="{{refreshing}}"
    bindscrolltolower="loadMore"
    lower-threshold="100"
  >
    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 工单列表 -->
    <view wx:else class="orders-list">
      <view 
        class="order-item card-hover"
        wx:for="{{filteredOrders}}"
        wx:for-item="order"
        wx:key="id"
        bindtap="viewOrderDetail"
        data-order="{{order}}"
      >
        <view class="order-header">
          <view class="order-title">
            <text class="title-text">{{order.title}}</text>
            <view class="urgent-badge" wx:if="{{order.urgentLevel === 'high'}}">
              <text class="urgent-text">紧急</text>
            </view>
          </view>
          <view class="status-badge" style="background-color: {{order.statusColor}}">
            <text class="status-text">{{order.statusText}}</text>
          </view>
        </view>

        <view class="order-content">
          <text class="order-desc">{{order.description}}</text>
          
          <view class="order-meta">
            <view class="meta-item">
              <image class="meta-icon" src="/static/icons/location.svg" mode="aspectFit"></image>
              <text class="meta-text">{{order.address}}</text>
            </view>
            <view class="meta-item">
              <image class="meta-icon" src="/static/icons/users.svg" mode="aspectFit"></image>
              <text class="meta-text">{{order.ownerName}}</text>
            </view>
            <view class="meta-item">
              <image class="meta-icon" src="/static/icons/clock.svg" mode="aspectFit"></image>
              <text class="meta-text">{{order.timeText}}</text>
            </view>
          </view>
        </view>

        <view class="order-actions">
          <button 
            class="action-btn contact"
            catchtap="contactOwner"
            data-order="{{order}}"
          >
            联系业主
          </button>
          <button 
            class="action-btn accept"
            catchtap="acceptOrder"
            data-order="{{order}}"
            wx:if="{{order.status === 'pending'}}"
          >
            接单
          </button>
          <button 
            class="action-btn complete"
            catchtap="completeOrder"
            data-order="{{order}}"
            wx:if="{{order.status === 'processing'}}"
          >
            完成
          </button>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{!hasOrders}}">
        <image class="empty-icon" src="/static/icons/repair.svg" mode="aspectFit"></image>
        <text class="empty-text">暂无{{activeTab === 'processing' ? '处理中' : '已完成'}}工单</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>
</view>
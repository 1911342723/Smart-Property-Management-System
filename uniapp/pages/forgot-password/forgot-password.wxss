/* pages/forgot-password/forgot-password.wxss */
.forgot-container {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: 40rpx;
}

.top-bar {
  display: flex;
  align-items: center;
  padding: calc(var(--status-bar-height, 20px) + 20rpx) 32rpx 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e9ecef;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #333333;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  flex: 1;
}

.forgot-form {
  padding: 60rpx 40rpx;
}

.form-header {
  margin-bottom: 60rpx;
}

.header-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #000000;
  margin-bottom: 16rpx;
}

.header-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.5;
}

.form-item {
  margin-bottom: 48rpx;
}

.label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 12rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #333333;
  transition: all 0.3s;
}

.input-field:focus {
  background: #ffffff;
  border-color: #333333;
}

.input-wrapper .input-field {
  padding-right: 80rpx;
}

.toggle-icon {
  position: absolute;
  right: 32rpx;
  font-size: 36rpx;
  opacity: 0.6;
}

.reset-btn {
  width: 100%;
  height: 96rpx;
  background: #000000;
  border: none;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.reset-btn:not(.disabled):active {
  transform: scale(0.98);
  background: #1a1a1a;
}

.reset-btn.disabled {
  opacity: 0.5;
  background: #666666;
}

.login-link {
  text-align: center;
  margin-top: 40rpx;
}

.link-text {
  font-size: 28rpx;
  color: #666666;
}

.link-action {
  font-size: 28rpx;
  color: #000000;
  font-weight: 600;
  margin-left: 8rpx;
}

.link-action:active {
  opacity: 0.7;
}

/* pages/test/api-test.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 20rpx;
}

.api-url {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f7fafc;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #4a5568;
}

.copy-btn {
  background: #2d3748 !important;
  color: white !important;
  border: none !important;
}

.test-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.test-btn {
  background: white !important;
  color: #2d3748 !important;
  border: 2rpx solid #e2e8f0 !important;
  border-radius: 12rpx !important;
  padding: 20rpx !important;
  font-size: 28rpx !important;
}

.test-btn:not([disabled]):active {
  background: #f7fafc !important;
}

.test-btn[disabled] {
  opacity: 0.5;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  background: #e2e8f0 !important;
  color: #2d3748 !important;
  border: none !important;
  border-radius: 12rpx !important;
  padding: 25rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
}

.action-btn.primary {
  background: #2d3748 !important;
  color: white !important;
}

.action-btn:not([disabled]):active {
  opacity: 0.8;
}

.action-btn[disabled] {
  opacity: 0.5;
}

.results {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.results-title {
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
  border-bottom: 2rpx solid #f7fafc;
}

.empty-results {
  padding: 60rpx;
  text-align: center;
  color: #a0aec0;
  font-size: 28rpx;
}

.result-item {
  padding: 30rpx;
  border-bottom: 2rpx solid #f7fafc;
  transition: background-color 0.2s;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background-color: #f7fafc;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #2d3748;
}

.result-status {
  font-size: 26rpx;
  font-weight: 500;
}

.result-time {
  font-size: 24rpx;
  color: #718096;
  margin-bottom: 10rpx;
}

.result-preview {
  font-size: 26rpx;
  color: #4a5568;
  padding: 15rpx;
  background: #f0fff4;
  border-radius: 8rpx;
  border-left: 6rpx solid #38a169;
}

.result-error {
  font-size: 26rpx;
  color: #e53e3e;
  padding: 15rpx;
  background: #fef5e7;
  border-radius: 8rpx;
  border-left: 6rpx solid #e53e3e;
}







/* pages/test/repair-form-test.wxss */
.test-container {
  padding: 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.test-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.test-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #2d3748;
  display: block;
  margin-bottom: 16rpx;
}

.test-subtitle {
  font-size: 28rpx;
  color: #718096;
}

.test-content {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.test-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
  display: block;
  margin-bottom: 24rpx;
}

.test-btn {
  width: 100%;
  padding: 30rpx !important;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #2d3748, #1a202c) !important;
  color: white !important;
  border: none !important;
  border-radius: 12rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
}

.test-btn[disabled] {
  background: #cbd5e0 !important;
  color: #a0aec0 !important;
}

.test-result {
  border-top: 2rpx solid #f7fafc;
  padding-top: 24rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
  display: block;
  margin-bottom: 16rpx;
}

.result-content {
  background: #f7fafc;
  padding: 24rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #38a169;
}

.result-text {
  font-size: 26rpx;
  color: #4a5568;
  line-height: 1.6;
}

.test-footer {
  margin-top: 40rpx;
  text-align: center;
}

.back-btn {
  padding: 24rpx 60rpx !important;
  background: #edf2f7 !important;
  color: #4a5568 !important;
  border: none !important;
  border-radius: 12rpx !important;
  font-size: 28rpx !important;
}







/* pages/common/activity-detail.wxss */
.activity-detail-container {
  min-height: 100vh;
  background: #f7fafc;
}

/* 错误状态样式 */
.error-container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.error-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: white;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.error-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 12rpx;
}

.error-message {
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.retry-btn {
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.retry-btn::after {
  border: none;
}

.activity-header {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.activity-image {
  width: 100%;
  height: 100%;
}

.activity-overlay {
  position: absolute;
  top: 0;
  right: 0;
  padding: 32rpx;
}

.activity-status {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(8rpx);
}

.activity-status.upcoming .status-text {
  color: #d69e2e;
}

.activity-status.registration .status-text {
  color: #38a169;
}

.activity-content {
  height: calc(100vh - 400rpx - 120rpx);
  background: #f7fafc;
}

.content-section {
  background: #ffffff;
  margin: 24rpx 32rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e2e8f0;
}

.activity-title {
  display: block;
  color: #2d3748;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
}

.meta-text {
  color: #4a5568;
  font-size: 26rpx;
}

.section-title {
  display: block;
  color: #2d3748;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.activity-description,
.activity-requirements,
.activity-contact {
  color: #4a5568;
  font-size: 26rpx;
  line-height: 1.6;
}

.activity-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #e2e8f0;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-btn {
  width: 100%;
  height: 88rpx;
  background: #2d3748;
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.action-btn:active {
  background: #1a202c;
  transform: translateY(-2rpx);
}

.btn-primary {
  background: #38a169;
}

.btn-primary:active {
  background: #2f855a;
}

.btn-success {
  background: #48bb78;
}

.btn-success:active {
  background: #38a169;
}

.btn-danger {
  background: #f56c6c;
}

.btn-danger:active {
  background: #f56565;
}

.bottom-placeholder {
  height: 40rpx;
}






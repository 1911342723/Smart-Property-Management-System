/* pages/common/my-registrations.wxss */

.container {
  padding: 0 0 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 筛选栏 */
.filter-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  flex: 1;
}

.filter-picker {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

/* 报名列表 */
.registration-list {
  padding: 20rpx;
}

.registration-item {
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.activity-image {
  width: 100%;
  height: 360rpx;
  background-color: #f0f0f0;
}

.registration-content {
  padding: 20rpx;
}

.registration-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.activity-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.registration-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  white-space: nowrap;
}

.status-registered {
  color: #2b6cb0;
  background-color: #ebf8ff;
}

.status-confirmed {
  color: #38a169;
  background-color: #f0fff4;
}

.status-cancelled {
  color: #e53e3e;
  background-color: #fff5f5;
}

.registration-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.info-label {
  color: #999;
  margin-right: 8rpx;
}

.registration-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.action-buttons {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  border: none;
}

.btn-outline {
  background-color: transparent;
  border: 1rpx solid #2b6cb0;
  color: #2b6cb0;
}

.btn-danger {
  background-color: #f56c6c;
  color: #fff;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.error {
  text-align: center;
  padding: 40rpx;
  color: #e53e3e;
  font-size: 28rpx;
}

.retry-btn {
  margin-top: 20rpx;
  color: #2b6cb0;
  font-size: 28rpx;
  text-decoration: underline;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}






/* pages/common/activity-list.wxss */

.container {
  padding: 0 0 30rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 筛选栏 */
.filter-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  flex: 1;
  margin: 0 10rpx;
}

.filter-picker {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

/* 活动列表 */
.activity-list {
  padding: 20rpx;
}

.activity-item {
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.activity-image {
  width: 100%;
  height: 360rpx;
  background-color: #f0f0f0;
}

.activity-content {
  padding: 20rpx;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.activity-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.activity-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
}

.status-registration {
  color: #2b6cb0;
  background-color: #ebf8ff;
}

.status-upcoming {
  color: #d69e2e;
  background-color: #fffff0;
}

.status-ongoing {
  color: #38a169;
  background-color: #f0fff4;
}

.activity-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.info-label {
  color: #999;
  margin-right: 8rpx;
}

.activity-summary {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.activity-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.participant-info {
  font-size: 24rpx;
  color: #666;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  border: none;
}

.btn-outline {
  background-color: transparent;
  border: 1rpx solid #2b6cb0;
  color: #2b6cb0;
}

.btn-primary {
  background-color: #2b6cb0;
  color: #fff;
}

.btn-success {
  background-color: #48bb78;
  color: #fff;
}

.btn-danger {
  background-color: #f56c6c;
  color: #fff;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.error {
  text-align: center;
  padding: 40rpx;
  color: #e53e3e;
  font-size: 28rpx;
}

.retry-btn {
  margin-top: 20rpx;
  color: #2b6cb0;
  font-size: 28rpx;
  text-decoration: underline;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

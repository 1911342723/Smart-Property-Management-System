.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f6faf9 0%, #eef6f4 100%);
  padding-bottom: 20rpx;
}

.page-header {
  background: linear-gradient(135deg, #115e59 0%, #0f766e 55%, #14b8a6 100%);
  padding: 60rpx 40rpx 44rpx;
  color: #ffffff;
}

.page-title {
  display: block;
  font-size: 46rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.parking-list {
  padding: 24rpx;
}

.parking-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 118, 110, 0.08);
  border: 1rpx solid rgba(15, 118, 110, 0.08);
}

.parking-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.parking-name {
  display: block;
  color: #16312f;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.parking-type {
  display: inline-block;
  color: #0f766e;
  font-size: 22rpx;
  background: rgba(20, 184, 166, 0.12);
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.parking-status {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #ffffff;
  flex-shrink: 0;
}

.status-AVAILABLE {
  background: #38a169;
}

.status-OCCUPIED {
  background: #0f766e;
}

.status-DISABLED {
  background: #718096;
}

.parking-details {
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 18rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-row.two-column {
  gap: 16rpx;
}

.detail-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-item-block {
  flex: 1 1 100%;
}

.detail-label {
  color: #718096;
  font-size: 24rpx;
}

.detail-value {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 500;
  word-break: break-all;
}

.detail-value.highlight {
  color: #b7791f;
}

.parking-actions {
  padding-top: 24rpx;
  border-top: 1rpx solid #e6eeec;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: none;
  border-radius: 14rpx;
  font-size: 26rpx;
  padding: 18rpx;
}

.detail-btn {
  background: rgba(15, 118, 110, 0.08);
  color: #0f766e;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 28rpx;
  opacity: 0.35;
}

.empty-text {
  font-size: 32rpx;
  color: #2d3748;
  margin-bottom: 14rpx;
  font-weight: 600;
}

.empty-desc {
  font-size: 26rpx;
  color: #718096;
  line-height: 1.6;
}

.refresh-indicator {
  text-align: center;
  color: #718096;
  font-size: 24rpx;
  padding-bottom: 24rpx;
}
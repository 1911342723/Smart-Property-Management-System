<!--pages/owner/repair-form.wxml-->
<view class="repair-form-container">
  <scroll-view scroll-y class="content">
    <!-- 页面头部 -->
    <view class="form-header">
      <view class="category-info">
        <text class="category-name">{{categoryInfo.name}}</text>
        <view class="category-desc">{{categoryInfo.description}}</view>
      </view>
      <view class="mode-toggle" wx:if="{{isQuick}}">
        <view class="quick-tag">快速报修</view>
      </view>
    </view>

    <!-- 问题标题 -->
    <view class="form-section">
      <view class="section-title">
        <text class="title-text">问题标题</text>
        <text class="required">*</text>
      </view>
      <input 
        class="form-input"
        placeholder="请简要描述问题"
        value="{{formData.title}}"
        bindinput="onTitleInput"
        maxlength="50"
      />
      <view class="char-count">{{formData.title.length}}/50</view>
    </view>

    <!-- 问题描述 -->
    <view class="form-section">
      <view class="section-title">
        <text class="title-text">问题描述</text>
        <text class="required">*</text>
      </view>
      <textarea 
        class="form-textarea"
        placeholder="请详细描述遇到的问题，便于师傅准确判断"
        value="{{formData.content}}"
        bindinput="onContentInput"
        maxlength="500"
        auto-height
        show-confirm-bar="{{false}}"
      />
      <view class="char-count">{{formData.content.length}}/500</view>
    </view>

    <!-- 紧急程度 -->
    <view class="form-section">
      <view class="section-title">
        <text class="title-text">紧急程度</text>
      </view>
      <view class="priority-options">
        <view 
          class="priority-item {{formData.priority === item.value ? 'active' : ''}}"
          wx:for="{{priorities}}" 
          wx:key="value"
          bindtap="selectPriority"
          data-priority="{{item.value}}"
          style="border-color: {{item.color}}"
        >
          <view class="priority-dot" style="background-color: {{item.color}}"></view>
          <text class="priority-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 上传图片 -->
    <view class="form-section">
      <view class="section-title">
        <text class="title-text">现场照片</text>
        <text class="subtitle-text">（选填，最多3张）</text>
      </view>
      <view class="image-upload-area">
        <view class="uploaded-images">
          <view 
            class="image-item" 
            wx:for="{{formData.images}}" 
            wx:key="index"
          >
            <image 
              class="uploaded-image" 
              src="{{item}}" 
              mode="aspectFill"
              bindtap="previewImage"
              data-index="{{index}}"
            />
            <view 
              class="delete-btn" 
              bindtap="deleteImage"
              data-index="{{index}}"
            >
              ×
            </view>
          </view>
        </view>
        <view 
          class="add-image-btn" 
          wx:if="{{formData.images.length < 3}}"
          bindtap="chooseImage"
        >
          <text class="add-icon">+</text>
          <text class="add-text">添加照片</text>
        </view>
      </view>
    </view>

    <!-- 联系信息 -->
    <view class="form-section">
      <view class="section-title">
        <text class="title-text">联系方式</text>
      </view>
      <view class="contact-info">
        <view class="contact-item">
          <text class="contact-label">手机号码</text>
          <input 
            class="contact-input"
            placeholder="请输入手机号"
            value="{{formData.phone}}"
            bindinput="onPhoneInput"
            type="number"
            maxlength="11"
          />
        </view>
        <view class="contact-item">
          <text class="contact-label">预约时间</text>
          <picker 
            mode="multiSelector" 
            range="{{timeRange}}"
            value="{{timeIndex}}"
            bindchange="onTimeChange"
          >
            <view class="picker-text">{{selectedTime || '请选择预约时间'}}</view>
          </picker>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部操作区 -->
  <view class="form-footer">
    <button 
      class="cancel-btn" 
      bindtap="cancelSubmit"
      disabled="{{submitting}}"
    >
      取消
    </button>
    <button 
      class="submit-btn" 
      bindtap="submitRepair"
      disabled="{{submitting || !canSubmit}}"
      loading="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交报修'}}
    </button>
  </view>
</view>


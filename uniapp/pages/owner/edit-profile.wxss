/* pages/owner/edit-profile.wxss */
.page-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 32rpx;
}

/* 头像编辑区域 */
.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}

.avatar-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-edit-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 8rpx 0;
  text-align: center;
  font-size: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  width: 24rpx;
  height: 24rpx;
  margin-bottom: 4rpx;
  filter: brightness(0) invert(1);
}

.edit-text {
  font-size: 18rpx;
  line-height: 1;
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 48rpx;
}

.section-title {
  padding: 32rpx 32rpx 16rpx;
  color: #2d3748;
  font-size: 32rpx;
  font-weight: 600;
  border-bottom: 1rpx solid #f1f3f5;
  background: #f8f9fa;
}

.form-item {
  padding: 32rpx;
  border-bottom: 1rpx solid #f1f3f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  color: #333333;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333333;
  border: none;
  background: transparent;
}

.form-input::placeholder {
  color: #999999;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333333;
  border: none;
  background: transparent;
  resize: none;
}

.form-textarea::placeholder {
  color: #999999;
}

.required {
  color: #e53e3e;
  margin-left: 4rpx;
}

.form-error {
  color: #e53e3e;
  font-size: 24rpx;
  margin-top: 8rpx;
  line-height: 1.4;
}

.char-count {
  text-align: right;
  color: #999999;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 性别选择 */
.gender-options {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.gender-option {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  color: #4a5568;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.gender-option.active {
  border-color: #2d3748;
  background: #2d3748;
  color: #ffffff;
}

.gender-option:active {
  transform: scale(0.98);
}

/* 日期选择器 */
.picker-display {
  padding: 16rpx 0;
  color: #333333;
  font-size: 28rpx;
  min-height: 44rpx;
  display: flex;
  align-items: center;
}

/* 保存按钮 */
.save-section {
  margin-top: 32rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2d3748 0%, #4a5568 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(45, 55, 72, 0.3);
}

.save-btn:disabled {
  background: #e2e8f0;
  color: #a0aec0;
  box-shadow: none;
}

.save-btn:active:not(:disabled) {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 12rpx rgba(45, 55, 72, 0.3);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
  transform: scale(0.8);
  transition: transform 0.3s ease;
}

.modal-overlay.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f1f3f5;
}

.modal-title {
  color: #333333;
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f7fafc;
  transition: background 0.2s ease;
}

.modal-close:active {
  background: #edf2f7;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

/* 头像选项 */
.avatar-options {
  padding: 32rpx;
}

.avatar-option {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #f7fafc;
  transition: background 0.2s ease;
}

.avatar-option:last-child {
  border-bottom: none;
}

.avatar-option:active {
  background: #f7fafc;
}

.option-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f7fafc;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.icon-text {
  font-size: 32rpx;
  line-height: 1;
}

.delete-icon {
  filter: hue-rotate(0deg) saturate(2) brightness(0.8);
}

.option-text {
  color: #333333;
  font-size: 28rpx;
}

.delete-text {
  color: #e53e3e;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .page-container {
    padding: 24rpx;
  }
  
  .avatar-container {
    width: 140rpx;
    height: 140rpx;
  }
  
  .form-item {
    padding: 24rpx;
  }
  
  .gender-options {
    gap: 12rpx;
  }
  
  .gender-option {
    height: 64rpx;
    font-size: 26rpx;
  }
}

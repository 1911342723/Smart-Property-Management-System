<!--pages/owner/notices.wxml-->
<view class="page-container">
  <!-- 自定义导航栏 -->
  <view class="custom-navbar">
    <view class="navbar-left">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="navbar-title">公告通知</text>
    </view>
    <view class="navbar-right">
      <view class="filter-btn" bindtap="showFilterModal">
        <text class="filter-icon">⋮</text>
      </view>
    </view>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tabs">
    <scroll-view scroll-x class="tabs-scroll">
      <view class="tabs-container">
        <view 
          class="tab-item {{activeType === item.value ? 'active' : ''}}"
          wx:for="{{noticeTypes}}"
          wx:key="value"
          bindtap="switchType"
          data-type="{{item.value}}"
        >
          <text class="tab-text">{{item.label}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 公告列表 -->
  <scroll-view 
    scroll-y 
    class="notice-list-container"
    bindscrolltolower="loadMore"
    refresher-enabled
    bindrefresherrefresh="onRefresh"
    refresher-triggered="{{refreshing}}"
  >
    <view class="notice-list">
      <view 
        class="notice-item"
        wx:for="{{notices}}"
        wx:key="id"
        bindtap="viewNoticeDetail"
        data-notice="{{item}}"
      >
        <view class="notice-header">
          <view class="notice-title-row">
            <text class="notice-title">{{item.title}}</text>
            <view class="notice-status {{item.priority}}">
              <text class="status-text">{{item.priorityText}}</text>
            </view>
          </view>
          <view class="notice-meta-row">
            <view class="notice-type {{item.type}}">
              <text class="type-text">{{item.typeText}}</text>
            </view>
            <text class="notice-date">{{item.dateText}}</text>
          </view>
        </view>
        
        <view class="notice-content">
          <text class="notice-summary">{{item.summary}}</text>
        </view>

        <view class="notice-footer">
          <view class="notice-stats">
            <view class="stat-item" wx:if="{{item.viewCount}}">
              <image class="stat-icon" src="/static/icons/eye.svg" mode="aspectFit"></image>
              <text class="stat-text">{{item.viewCount}}</text>
            </view>
            <view class="stat-item" wx:if="{{item.publisherName}}">
              <image class="stat-icon" src="/static/icons/user.svg" mode="aspectFit"></image>
              <text class="stat-text">{{item.publisherName}}</text>
            </view>
          </view>
          <view class="notice-actions">
            <text class="action-text">查看详情</text>
            <image class="action-arrow" src="/static/icons/arrow-right.svg" mode="aspectFit"></image>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="load-status">
      <view class="loading-indicator" wx:if="{{loading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>
      <view class="no-more" wx:elif="{{noMore && notices.length > 0}}">
        <text class="no-more-text">没有更多了</text>
      </view>
      <view class="empty-state" wx:elif="{{notices.length === 0 && !loading}}">
        <image class="empty-icon" src="/static/images/empty-notice.png" mode="aspectFit"></image>
        <text class="empty-text">暂无公告通知</text>
      </view>
    </view>
  </scroll-view>

  <!-- 筛选弹窗 -->
  <view class="filter-modal" wx:if="{{showFilterModal}}">
    <view class="modal-mask" bindtap="hideFilterModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">筛选公告</text>
        <view class="modal-close" bindtap="hideFilterModal">
          <image class="close-icon" src="/static/icons/close.svg" mode="aspectFit"></image>
        </view>
      </view>
      
      <view class="filter-section">
        <text class="filter-label">公告类型</text>
        <view class="filter-options">
          <view 
            class="filter-option {{filterType === item.value ? 'selected' : ''}}"
            wx:for="{{allNoticeTypes}}"
            wx:key="value"
            bindtap="selectFilterType"
            data-type="{{item.value}}"
          >
            <text class="option-text">{{item.label}}</text>
            <image class="option-check" src="/static/icons/check.svg" mode="aspectFit" wx:if="{{filterType === item.value}}"></image>
          </view>
        </view>
      </view>

      <view class="filter-section">
        <text class="filter-label">优先级</text>
        <view class="filter-options">
          <view 
            class="filter-option {{filterPriority === item.value ? 'selected' : ''}}"
            wx:for="{{priorityOptions}}"
            wx:key="value"
            bindtap="selectFilterPriority"
            data-priority="{{item.value}}"
          >
            <text class="option-text">{{item.label}}</text>
            <image class="option-check" src="/static/icons/check.svg" mode="aspectFit" wx:if="{{filterPriority === item.value}}"></image>
          </view>
        </view>
      </view>

      <view class="modal-actions">
        <button class="reset-btn" bindtap="resetFilter">重置</button>
        <button class="confirm-btn" bindtap="applyFilter">确定</button>
      </view>
    </view>
  </view>
</view>




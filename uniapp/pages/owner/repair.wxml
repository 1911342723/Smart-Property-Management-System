<!--pages/owner/repair.wxml-->
<view class="repair-container">
  <view class="page-header">
    <text class="page-title">物业报修</text>
    <text class="page-subtitle">快速提交报修申请，实时跟踪处理进度</text>
  </view>
  
  <scroll-view scroll-y class="content">
    <!-- 快速报修 -->
    <view class="quick-repair-section">
      <view class="section-header">
        <text class="section-title">快速报修</text>
        <text class="section-subtitle">选择问题类型</text>
      </view>
      
      <view class="repair-categories">
        <view 
          class="category-item"
          wx:for="{{repairCategories}}"
          wx:key="id"
          bindtap="selectCategory"
          data-category="{{item}}"
        >
          <view class="category-icon" style="background: {{item.gradient}}">
            <image class="icon-svg" src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <view class="category-info">
            <text class="category-name">{{item.name}}</text>
            <text class="category-desc">{{item.description}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 我的报修 -->
    <view class="my-repairs-section">
      <view class="section-header">
        <text class="section-title">我的报修</text>
        <text class="section-action" bindtap="viewAllRepairs">查看全部</text>
      </view>
      
      <!-- 空状态 -->
      <view wx:if="{{recentRepairs.length === 0}}" class="empty-state">
        <image class="empty-icon" src="/static/icons/repair.svg" mode="aspectFit" />
        <text class="empty-text">暂无报修记录</text>
        <text class="empty-hint">点击上方分类快速报修</text>
      </view>
      
      <!-- 报修列表 -->
      <view wx:else class="repair-list">
        <view 
          class="repair-item card-hover"
          wx:for="{{recentRepairs}}"
          wx:key="id"
          bindtap="viewRepairDetail"
          data-repair="{{item}}"
        >
          <view class="repair-header">
            <view class="repair-info">
              <text class="repair-title">{{item.title}}</text>
              <view class="repair-meta">
                <text class="repair-time">{{item.timeText}}</text>
                <text class="repair-no" wx:if="{{item.sourceData.orderNo}}">{{item.sourceData.orderNo}}</text>
              </view>
            </view>
            <view class="repair-status-wrapper">
              <view class="status-badge" style="background-color: {{item.statusColor}}">
                {{item.statusText}}
              </view>
              <!-- 评价按钮 - 与状态标签平行 -->
              <button 
                wx:if="{{item.status === 'completed' && !item.sourceData.rating}}"
                class="rate-btn-inline" 
                bindtap="rateRepair" 
                data-repair="{{item}}" 
                catchtap="true"
              >
                评价
              </button>
            </view>
          </view>
          
          <view class="repair-content">
            <text class="repair-desc">{{item.description}}</text>
          </view>
          
          <view class="repair-footer" wx:if="{{item.sourceData.assigneeName || item.sourceData.priority}}">
            <view class="repair-worker" wx:if="{{item.sourceData.assigneeName}}">
              <text class="worker-label">维修师傅：</text>
              <text class="worker-name">{{item.sourceData.assigneeName}}</text>
            </view>
            <view class="repair-priority" wx:if="{{item.sourceData.priority}}">
              <view class="priority-dot" style="background-color: {{item.statusColor}}"></view>
              <text class="priority-text">{{item.sourceData.priority === 'HIGH' || item.sourceData.priority === 'URGENT' ? '紧急' : '普通'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 报修统计 -->
    <view class="repair-stats">
      <view class="section-header">
        <text class="section-title">报修统计</text>
      </view>
      
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-number">{{repairStats.total}}</text>
          <text class="stat-label">总计</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{repairStats.processing}}</text>
          <text class="stat-label">处理中</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{repairStats.completed}}</text>
          <text class="stat-label">已完成</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>
</view>
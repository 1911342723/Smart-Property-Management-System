/* pages/owner/payment.wxss */
.payment-container {
  min-height: 100vh;
  background: #f7fafc;
}

.page-header {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  padding: calc(var(--status-bar-height, 20px) + 40rpx) 32rpx 40rpx;
  border-bottom: 1rpx solid #dee2e6;
}

.page-title {
  color: #333333;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
}

.page-subtitle {
  color: #6c757d;
  font-size: 26rpx;
  display: block;
}

.content {
  height: calc(100vh - 200rpx);
  padding: 32rpx;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

/* 费用概览 */
.overview-section {
  margin-bottom: 40rpx;
}

.overview-card {
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(45, 55, 72, 0.2);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.overview-title {
  font-size: 28rpx;
  opacity: 0.9;
}

.overview-amount {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.amount-symbol {
  font-size: 24rpx;
  opacity: 0.8;
}

.amount-number {
  font-size: 48rpx;
  font-weight: 600;
}

.overview-desc {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.desc-text, .desc-time {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 费用列表 */
.bills-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  color: #2d3748;
  font-size: 32rpx;
  font-weight: 600;
}

.section-action {
  color: #2d3748;
  font-size: 26rpx;
  opacity: 0.7;
}

.bills-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bill-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #e2e8f0;
  transition: all 0.2s ease;
  position: relative;
  cursor: pointer;
}

.bill-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.bill-item.overdue {
  border-left: 6rpx solid #e53e3e;
}

.bill-item.selected {
  border-color: #2d3748;
  background: rgba(45, 55, 72, 0.02);
  box-shadow: 0 4rpx 16rpx rgba(45, 55, 72, 0.15);
}

.bill-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bill-icon .icon-svg {
  width: 36rpx;
  height: 36rpx;
  filter: invert(1);
}

.bill-content {
  flex: 1;
  min-width: 0;
}

.bill-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.bill-title {
  color: #2d3748;
  font-size: 28rpx;
  font-weight: 600;
}

.bill-status {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
}

.bill-status.unpaid {
  background: rgba(214, 158, 46, 0.1);
  color: #d69e2e;
}

.bill-status.overdue {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
}

.bill-desc {
  color: #718096;
  font-size: 24rpx;
  margin-bottom: 4rpx;
  display: block;
}

.bill-period {
  color: #a0aec0;
  font-size: 22rpx;
  display: block;
}

.bill-amount {
  text-align: right;
  flex-shrink: 0;
}

.amount-text {
  color: #2d3748;
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.due-date {
  color: #e53e3e;
  font-size: 20rpx;
}

/* 缴费项目选择器 */
.bill-selector {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.selector-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.selector-checkbox.checked {
  border-color: #2d3748;
  background: #2d3748;
}

.check-icon {
  width: 24rpx;
  height: 24rpx;
  filter: invert(1);
}

/* 缴费说明 */
.notice-section {
  margin-bottom: 40rpx;
}

.notice-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
}

.notice-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.notice-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.7;
}

.notice-title {
  color: #2d3748;
  font-size: 28rpx;
  font-weight: 600;
}

.notice-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.notice-text {
  color: #718096;
  font-size: 24rpx;
  line-height: 1.6;
}

/* 浮动缴费按钮 */
.floating-pay-btn {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  color: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(45, 55, 72, 0.25), 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  min-width: 280rpx;
  backdrop-filter: blur(10rpx);
}

.floating-pay-btn:active {
  transform: translateX(-50%) scale(0.96);
  box-shadow: 0 8rpx 24rpx rgba(45, 55, 72, 0.3), 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.pay-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  align-items: center;
}

.pay-count {
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  font-weight: 500;
}

.pay-amount {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.pay-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.bottom-placeholder {
  height: 120rpx;
}
/* pages/owner/repair-detail.wxss */
page {
  background-color: #f5f5f5;
  height: 100vh;
}

.repair-detail-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  width: 100vw;
  max-width: 100vw;
  overflow-x: hidden;
  box-sizing: border-box;
}

/* 加载状态 */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #a0aec0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top: 4rpx solid #2d3748;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

/* 内容区域 */
.detail-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.content {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
  width: 100%;
  overflow-x: hidden;
}

/* 状态卡片 */
.status-card {
  background: linear-gradient(135deg, #2d3748, #1a202c);
  color: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(45, 55, 72, 0.3);
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.status-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-no {
  font-size: 32rpx;
  font-weight: 600;
  opacity: 0.9;
}

.status-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: white;
}

.priority-info {
  text-align: right;
}

.priority-badge {
  font-size: 26rpx;
  font-weight: 500;
}

.order-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.submit-time {
  font-size: 26rpx;
  opacity: 0.8;
}

/* 详情区块 */
.detail-section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f7fafc;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.info-label {
  font-size: 28rpx;
  color: #718096;
  min-width: 140rpx;
}

.info-value {
  font-size: 28rpx;
  color: #2d3748;
  font-weight: 500;
  text-align: right;
  flex: 1;
  min-width: 0;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.cost-value {
  color: #38a169;
  font-weight: 600;
}

/* 问题描述 */
.description-text {
  font-size: 28rpx;
  color: #4a5568;
  line-height: 1.6;
  word-break: break-word;
  overflow-wrap: break-word;
  white-space: pre-wrap;
  width: 100%;
  box-sizing: border-box;
}

/* 图片网格 */
.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  width: 100%;
  box-sizing: border-box;
}

.image-item {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.repair-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 时间轴 */
.timeline {
  position: relative;
  padding-left: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  bottom: 20rpx;
  width: 4rpx;
  background: #e2e8f0;
  border-radius: 2rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -32rpx;
  top: 8rpx;
  width: 24rpx;
  height: 24rpx;
  background: #e2e8f0;
  border-radius: 50%;
  border: 4rpx solid white;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.timeline-item.active .timeline-dot {
  background: #38a169;
}

.timeline-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  width: 100%;
  box-sizing: border-box;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3748;
}

.timeline-time {
  font-size: 24rpx;
  color: #718096;
}

.timeline-pending {
  font-size: 24rpx;
  color: #a0aec0;
  font-style: italic;
}

/* 评价显示 */
.rating-display {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 8rpx;
}

.star {
  font-size: 40rpx;
  color: #e2e8f0;
  transition: color 0.2s;
}

.star.filled {
  color: #f6ad55;
}

.rating-feedback {
  font-size: 28rpx;
  color: #4a5568;
  line-height: 1.6;
  padding: 20rpx;
  background: #f7fafc;
  border-radius: 12rpx;
  border-left: 6rpx solid #38a169;
}

/* 底部操作区 */
.bottom-actions {
  background: white;
  padding: 30rpx;
  border-top: 2rpx solid #f7fafc;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
}

.action-btn {
  flex: 1;
  padding: 26rpx !important;
  border-radius: 12rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
  border: none !important;
}

.action-btn.primary {
  background: linear-gradient(135deg, #38a169, #2f855a) !important;
  color: white !important;
}

.action-btn.secondary {
  background: #f7fafc !important;
  color: #2d3748 !important;
  border: 2rpx solid #e2e8f0 !important;
}

.action-btn:not(.primary):not(.secondary) {
  background: #edf2f7 !important;
  color: #4a5568 !important;
}

/* 评价弹窗 */
.rating-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: relative;
  width: 600rpx;
  max-width: 90%;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f7fafc;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
}

.close-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #a0aec0;
}

.modal-body {
  padding: 30rpx;
}

.rating-section {
  margin-bottom: 30rpx;
}

.rating-label,
.feedback-label {
  display: block;
  font-size: 28rpx;
  color: #2d3748;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.rating-stars {
  display: flex;
  gap: 12rpx;
}

.feedback-section {
  margin-top: 30rpx;
}

.feedback-input {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  background: #f7fafc;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 2rpx solid #f7fafc;
}

.cancel-btn,
.submit-btn {
  flex: 1;
  padding: 26rpx !important;
  border-radius: 12rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
  border: none !important;
}

.cancel-btn {
  background: #f7fafc !important;
  color: #4a5568 !important;
}

.submit-btn {
  background: linear-gradient(135deg, #38a169, #2f855a) !important;
  color: white !important;
}

/* 响应式设计 */
@media screen and (max-width: 600rpx) {
  .content {
    padding: 16rpx;
  }
  
  .status-card,
  .detail-section {
    padding: 24rpx;
  }
  
  .status-header {
    flex-direction: column;
    gap: 16rpx;
  }
  
  .priority-info {
    text-align: left;
  }
  
  .info-item {
    flex-direction: column;
    align-items: flex-start;
    gap: 8rpx;
  }
  
  .info-value {
    text-align: left;
    width: 100%;
  }
  
  .images-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .bottom-actions {
    flex-direction: column;
    padding: 20rpx;
  }
  
  .timeline {
    padding-left: 32rpx;
  }
}
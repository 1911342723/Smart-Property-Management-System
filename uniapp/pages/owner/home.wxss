/* pages/owner/home.wxss */
.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #f1f3f5 50%, #e9ecef 100%);
}

/* 自定义导航栏 */
.custom-navbar {
  background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
  padding: calc(var(--status-bar-height, 20px) + 20rpx) 32rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: none;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
  width: 100%;
  box-sizing: border-box;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.user-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.user-text .greeting {
  color: #6c757d;
  font-size: 22rpx;
}

.user-text .username {
  color: #333333;
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.navbar-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
  margin-left: 24rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
}

.action-btn:active {
  background: rgba(248, 249, 250, 0.95);
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background: #e53e3e;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 600;
  padding: 2rpx 6rpx;
  border-radius: 10rpx;
  min-width: 20rpx;
  height: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(229, 62, 62, 0.3);
  border: 1rpx solid #ffffff;
}

.action-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.7;
}

/* 页面内容 */
.page-content {
  height: calc(100vh - 160rpx);
  padding: 0 32rpx 160rpx;
  box-sizing: border-box;
  margin-top: -20rpx;
  position: relative;
  z-index: 5;
}

/* 快速服务 */
.quick-services {
  margin: 48rpx 0 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  color: #2d3748;
  font-size: 32rpx;
  font-weight: 600;
}

.section-action {
  color: #2d3748;
  font-size: 26rpx;
  opacity: 0.7;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.service-item {
  background: linear-gradient(145deg, #ffffff 0%, #fafbfc 100%);
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.service-item:active {
  transform: translateY(-6rpx) scale(0.98);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12), 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.service-item::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: var(--gradient);
  opacity: 0.05;
  z-index: 0;
}

.service-icon {
  width: 88rpx;
  height: 88rpx;
  background: var(--gradient);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.icon-svg {
  width: 44rpx;
  height: 44rpx;
  filter: invert(1);
}

.service-info {
  flex: 1;
  position: relative;
  z-index: 1;
}

.service-name {
  color: #1a202c;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  display: block;
  letter-spacing: 0.5rpx;
}

.service-desc {
  color: #4a5568;
  font-size: 22rpx;
  line-height: 1.5;
  opacity: 0.8;
}

.service-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #e53e3e;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  min-width: 32rpx;
  text-align: center;
  z-index: 2;
}

/* 房屋信息卡片 */
.house-info-card {
  background: linear-gradient(145deg, #ffffff 0%, #fafbfc 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06), 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.house-card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.house-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(45, 55, 72, 0.2);
}

.house-icon-svg {
  width: 36rpx;
  height: 36rpx;
  filter: invert(1);
}

.house-info {
  flex: 1;
  min-width: 0;
}

.house-title {
  color: #1a202c;
  font-size: 28rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 6rpx;
  letter-spacing: 0.3rpx;
}

.house-address {
  color: #4a5568;
  font-size: 24rpx;
  opacity: 0.8;
  line-height: 1.4;
}

.house-edit-btn {
  width: 48rpx;
  height: 48rpx;
  background: rgba(45, 55, 72, 0.1);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.house-edit-btn:active {
  background: rgba(45, 55, 72, 0.15);
  transform: scale(0.95);
}

.edit-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.7;
}

.house-details {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-row {
  display: flex;
  gap: 32rpx;
}

.detail-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background: rgba(248, 250, 252, 0.8);
  border-radius: 16rpx;
  border: 1rpx solid rgba(226, 232, 240, 0.6);
}

.detail-label {
  color: #718096;
  font-size: 22rpx;
  font-weight: 500;
}

.detail-value {
  color: #1a202c;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
}

/* 待办事项 */
.todo-section {
  margin-bottom: 48rpx;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.todo-item {
  background: linear-gradient(145deg, #ffffff 0%, #fafbfc 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06), 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.todo-item:active {
  transform: translateY(-4rpx) scale(0.98);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.1), 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.todo-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
}

.todo-icon .icon-svg {
  width: 28rpx;
  height: 28rpx;
  filter: invert(1);
}

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title {
  color: #1a202c;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
  display: block;
  letter-spacing: 0.3rpx;
}

.todo-desc {
  color: #4a5568;
  font-size: 24rpx;
  margin-bottom: 4rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  opacity: 0.8;
}

.todo-time {
  color: #718096;
  font-size: 22rpx;
  opacity: 0.7;
}

.todo-status {
  text-align: right;
  flex-shrink: 0;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}


/* 社区活动 */
.activity-section {
  margin-bottom: 80rpx;
  padding-bottom: 80rpx;
}

.activity-scroll {
  white-space: nowrap;
}

.activity-list {
  display: flex;
  gap: 20rpx;
  padding: 0 4rpx;
}

.activity-item {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  width: 280rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
  transition: all 0.2s ease;
}

.activity-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.activity-image-container {
  position: relative;
  height: 160rpx;
  overflow: hidden;
}

.activity-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.activity-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.3) 100%);
  display: flex;
  align-items: flex-end;
  padding: 16rpx;
}

.activity-status {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(8rpx);
  font-size: 22rpx;
  font-weight: 500;
}

.activity-status.upcoming .status-text {
  color: #d69e2e;
}

.activity-status.registration .status-text {
  color: #38a169;
}

.activity-info {
  padding: 20rpx;
  min-height: 120rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.activity-title {
  color: #2d3748;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.activity-time {
  color: #718096;
  font-size: 22rpx;
  margin-bottom: 8rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-desc {
  color: #a0aec0;
  font-size: 20rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  word-break: break-all;
  margin-bottom: 12rpx;
  flex: 1;
}

.activity-meta {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-icon {
  width: 16rpx;
  height: 16rpx;
  opacity: 0.6;
}

.meta-text {
  color: #718096;
  font-size: 20rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.activity-actions {
  margin-top: auto;
}

.register-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  padding: 8rpx 16rpx;
  min-height: 56rpx;
  line-height: 1.2;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
  transition: all 0.2s ease;
}

.register-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 1rpx 4rpx rgba(102, 126, 234, 0.4);
}

/* 活动状态样式优化 */
.activity-status.UPCOMING .status-text {
  color: #d69e2e;
}

.activity-status.REGISTRATION .status-text {
  color: #38a169;
}

.activity-status.ONGOING .status-text {
  color: #3182ce;
}

.activity-status.COMPLETED .status-text {
  color: #718096;
}

.activity-status.CANCELLED .status-text {
  color: #e53e3e;
}

/* 活动错误状态 */
.activity-error, .activity-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  background: linear-gradient(145deg, #ffffff 0%, #fafbfc 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  margin: 0 4rpx;
}

.error-icon, .empty-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.error-message, .empty-message {
  color: #718096;
  font-size: 26rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.retry-btn {
  background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.retry-btn::after {
  border: none;
}

.bottom-placeholder {
  height: 120rpx;
}

/* 公告通知样式 */
.notice-section {
  padding: 0 32rpx 32rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  font-size: 32rpx;
  line-height: 1;
}

.notice-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 8rpx rgba(102, 126, 234, 0.3);
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notice-item {
  position: relative;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e2e8f0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}

.notice-item.priority-high {
  border-left: 4rpx solid #ff4d4f;
  background: linear-gradient(90deg, rgba(255, 77, 79, 0.02) 0%, #ffffff 100%);
}

.notice-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.12);
}

.priority-indicator {
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background: linear-gradient(180deg, #ff4d4f 0%, #ff7875 100%);
}

.notice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.notice-type-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #e6f7ff;
  color: #1890ff;
  font-size: 22rpx;
  font-weight: 500;
  transition: all 0.2s ease;
}

.notice-type-badge.urgent {
  background: linear-gradient(135deg, #fff1f0 0%, #ffccc7 100%);
  color: #ff4d4f;
  font-weight: 600;
  box-shadow: 0 2rpx 4rpx rgba(255, 77, 79, 0.2);
}

.notice-time {
  color: #8c8c8c;
  font-size: 22rpx;
}

.notice-title {
  color: #2d3748;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: block;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.priority-icon {
  margin-right: 6rpx;
  font-size: 24rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.8;
    transform: scale(1.1);
  }
}

.notice-summary {
  color: #718096;
  font-size: 24rpx;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: block;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.notice-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.publisher-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.publisher-icon {
  font-size: 24rpx;
  opacity: 0.6;
}

.notice-publisher {
  color: #8c8c8c;
  font-size: 22rpx;
}

.notice-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.notice-views {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.view-icon {
  font-size: 24rpx;
  opacity: 0.5;
}

.stat-text {
  color: #8c8c8c;
  font-size: 22rpx;
}
/* pages/owner/house-info.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 40rpx;
  color: white;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.page-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

/* 房屋列表 */
.room-list {
  padding: 20rpx;
}

.room-card {
  background: white;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 房屋头部信息 */
.room-header {
  margin-bottom: 24rpx;
}

.room-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.room-address {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  flex: 1;
}

.room-status {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: white;
}

.status-VACANT {
  background-color: #a0aec0;
}

.status-OCCUPIED {
  background-color: #38a169;
}

.status-RENTED {
  background-color: #d69e2e;
}

.room-type {
  font-size: 26rpx;
  color: #718096;
}

/* 房屋详情 */
.room-details {
  margin-bottom: 24rpx;
}

.detail-row {
  display: flex;
  margin-bottom: 16rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-item {
  flex: 1;
  display: flex;
  align-items: center;
}

.detail-label {
  font-size: 26rpx;
  color: #718096;
  width: 120rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #2d3748;
  font-weight: 500;
}

/* 操作按钮 */
.room-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 24rpx;
  border-top: 1px solid #e2e8f0;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
  gap: 8rpx;
}

.detail-btn {
  background-color: #edf2f7;
  color: #4a5568;
}

.edit-btn {
  background-color: #667eea;
  color: white;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #4a5568;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.empty-desc {
  font-size: 26rpx;
  color: #718096;
  line-height: 1.5;
}

/* 模态框样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  background: white;
  border-radius: 24rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1px solid #e2e8f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.modal-close {
  font-size: 40rpx;
  color: #a0aec0;
  cursor: pointer;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  padding: 20rpx 30rpx 30rpx;
  border-top: 1px solid #e2e8f0;
}

/* 编辑表单 */
.edit-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 28rpx;
  color: #4a5568;
  font-weight: 500;
}

.form-value {
  font-size: 30rpx;
  color: #2d3748;
  padding: 16rpx 0;
}

.form-input {
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.form-input:focus {
  border-color: #667eea;
  outline: none;
}

.form-picker {
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  background-color: #fff;
}

.picker-value {
  font-size: 28rpx;
  color: #2d3748;
}

.form-value.readonly {
  font-size: 28rpx;
  color: #718096;
  padding: 16rpx 0;
}

.form-note {
  font-size: 24rpx;
  color: #a0aec0;
  margin-top: 8rpx;
  display: block;
}

/* 模态框操作按钮 */
.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.cancel-btn {
  background-color: #edf2f7;
  color: #4a5568;
}

.confirm-btn {
  background-color: #667eea;
  color: white;
}

/* 刷新指示器 */
.refresh-indicator {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  z-index: 999;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .room-actions {
    flex-direction: column;
  }
  
  .action-btn {
    margin-bottom: 16rpx;
  }
  
  .action-btn:last-child {
    margin-bottom: 0;
  }
}

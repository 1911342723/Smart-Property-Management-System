/* pages/owner/rate-order.wxss */
.rate-container {
  width: 100vw;
  height: 100vh;
  background: #f8f9fa;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #fff;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.status-bar {
  width: 100%;
  background: #fff;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 44rpx;
  color: #333;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #000;
}

.placeholder {
  width: 64rpx;
}

/* 内容区域 */
.content {
  flex: 1;
  width: 100%;
  padding: 32rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* 工单信息卡片 */
.order-info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.order-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 16rpx;
}

.order-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-no,
.complete-time {
  font-size: 24rpx;
  color: #666;
}

/* 维修工卡片 */
.worker-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.worker-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.worker-info {
  display: flex;
  flex-direction: column;
}

.worker-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 8rpx;
}

.worker-role {
  font-size: 24rpx;
  color: #666;
}

/* 评分区域 */
.rating-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #000;
  margin-bottom: 32rpx;
  align-self: flex-start;
}

.star-rating {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.star {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.star-icon {
  font-size: 64rpx;
  color: #ddd;
}

.star.active .star-icon {
  color: #FFB800;
}

.rating-text {
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
}

/* 详细评分 */
.detail-ratings {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.rating-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.rating-item:last-child {
  border-bottom: none;
}

.rating-label {
  font-size: 28rpx;
  color: #333;
}

.star-group {
  display: flex;
  gap: 8rpx;
}

.star-small {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.star-small .star-icon {
  font-size: 40rpx;
  color: #ddd;
}

.star-small.active .star-icon {
  color: #FFB800;
}

/* 标签区域 */
.tags-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  border: 2rpx solid #e0e0e0;
  background: #fff;
}

.tag-item.selected {
  background: #000;
  border-color: #000;
}

.tag-text {
  font-size: 26rpx;
  color: #333;
}

.tag-item.selected .tag-text {
  color: #fff;
}

/* 评价内容 */
.content-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* 图片上传 */
.images-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.images-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  padding-top: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}

.upload-btn {
  width: 100%;
  height: 0;
  padding-top: 100%;
  position: relative;
  border: 2rpx dashed #ddd;
  border-radius: 12rpx;
  background: #fafafa;
}

.upload-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -80%);
  font-size: 64rpx;
  color: #999;
  line-height: 1;
}

.upload-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, 60%);
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}

/* 匿名选项 */
.anonymous-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.anonymous-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.anonymous-text {
  font-size: 28rpx;
  color: #333;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.checkbox.checked {
  background: #000;
  border-color: #000;
}

.check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.bottom-placeholder {
  height: 40rpx;
}

/* 提交按钮 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #000;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.submit-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.submit-btn.disabled {
  background: #999;
  opacity: 0.6;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

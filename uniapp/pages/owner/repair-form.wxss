/* pages/owner/repair-form.wxss */
page {
  background-color: #f5f5f5;
  height: 100vh;
}

.repair-form-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.content {
  flex: 1;
  padding: 20rpx;
}

/* 页面头部 */
.form-header {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.category-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.category-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3748;
}

.category-desc {
  font-size: 26rpx;
  color: #718096;
}

.mode-toggle {
  margin-top: 20rpx;
}

.quick-tag {
  display: inline-block;
  background: linear-gradient(135deg, #38a169, #2f855a);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 表单区块 */
.form-section {
  background: white;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d3748;
}

.subtitle-text {
  font-size: 24rpx;
  color: #718096;
  margin-left: 10rpx;
}

.required {
  color: #e53e3e;
  margin-left: 8rpx;
  font-size: 32rpx;
}

/* 输入框样式 */
.form-input {
  width: 100%;
  padding: 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2d3748;
  background-color: #f7fafc;
}

.form-input:focus {
  border-color: #2d3748;
  background-color: white;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #2d3748;
  background-color: #f7fafc;
  line-height: 1.6;
}

.form-textarea:focus {
  border-color: #2d3748;
  background-color: white;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #a0aec0;
  margin-top: 10rpx;
}

/* 优先级选择 */
.priority-options {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.priority-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  background-color: #f7fafc;
  transition: all 0.2s;
  flex: 1;
  min-width: 120rpx;
}

.priority-item.active {
  background-color: white;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.priority-label {
  font-size: 28rpx;
  color: #2d3748;
  font-weight: 500;
}

/* 图片上传 */
.image-upload-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.uploaded-images {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #e53e3e;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.add-image-btn {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed #cbd5e0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #a0aec0;
  background-color: #f7fafc;
}

.add-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
}

/* 联系信息 */
.contact-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.contact-label {
  font-size: 28rpx;
  color: #4a5568;
  min-width: 120rpx;
  font-weight: 500;
}

.contact-input {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f7fafc;
}

.picker-text {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 8rpx;
  font-size: 28rpx;
  background-color: #f7fafc;
  color: #4a5568;
}

/* 底部操作区 */
.form-footer {
  background: white;
  padding: 30rpx;
  border-top: 2rpx solid #f7fafc;
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.1);
}

.cancel-btn {
  flex: 1;
  padding: 26rpx !important;
  background-color: #f7fafc !important;
  color: #4a5568 !important;
  border: 2rpx solid #e2e8f0 !important;
  border-radius: 12rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
}

.cancel-btn:active {
  background-color: #edf2f7 !important;
}

.submit-btn {
  flex: 2;
  padding: 26rpx !important;
  background: linear-gradient(135deg, #2d3748, #1a202c) !important;
  color: white !important;
  border: none !important;
  border-radius: 12rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
}

.submit-btn[disabled] {
  background: #cbd5e0 !important;
  color: #a0aec0 !important;
}

.submit-btn:not([disabled]):active {
  opacity: 0.9;
}

/* 响应式设计 */
@media screen and (max-width: 600rpx) {
  .priority-options {
    flex-direction: column;
  }
  
  .contact-item {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .contact-label {
    min-width: auto;
  }
  
  .contact-input,
  .picker-text {
    width: 100%;
  }
}
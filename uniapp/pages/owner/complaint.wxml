<!--pages/owner/complaint.wxml-->
<view class="complaint-container">
  <view class="page-header">
    <text class="page-title">投诉建议</text>
    <text class="page-subtitle">反映问题，提出建议，我们用心倾听</text>
  </view>
  
  <scroll-view scroll-y class="content">
    <!-- 快速入口 -->
    <view class="quick-entry-section">
      <view class="section-header">
        <text class="section-title">快速投诉</text>
        <text class="section-subtitle">选择问题类型，快速提交</text>
      </view>
      
      <view class="entry-grid">
        <view 
          class="entry-item"
          wx:for="{{complaintTypes}}"
          wx:key="id"
          bindtap="selectComplaintType"
          data-type="{{item}}"
        >
          <view class="entry-icon" style="background: {{item.gradient}}">
            <image class="icon-svg" src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <text class="entry-title">{{item.name}}</text>
          <text class="entry-desc">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 我的投诉 -->
    <view class="my-complaints-section">
      <view class="section-header">
        <text class="section-title">我的投诉</text>
        <text class="section-action" bindtap="viewAllComplaints">查看全部</text>
      </view>
      
      <view class="complaints-list">
        <view 
          class="complaint-item"
          wx:for="{{recentComplaints}}"
          wx:key="id"
          bindtap="viewComplaintDetail"
          data-complaint="{{item}}"
        >
          <view class="complaint-icon" style="background-color: {{item.statusColor}}">
            <image class="icon-svg" src="{{item.iconUrl}}" mode="aspectFit"></image>
          </view>
          <view class="complaint-content">
            <view class="complaint-header">
              <text class="complaint-title">{{item.title}}</text>
              <view class="complaint-status {{item.status}}">
                <text class="status-text">{{item.statusText}}</text>
              </view>
            </view>
            <text class="complaint-desc">{{item.description}}</text>
            <text class="complaint-time">{{item.timeText}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 处理统计 -->
    <view class="stats-section">
      <view class="section-header">
        <text class="section-title">处理统计</text>
      </view>
      
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-number">{{complaintStats.total}}</text>
          <text class="stat-label">总计</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{complaintStats.pending}}</text>
          <text class="stat-label">待处理</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{complaintStats.processing}}</text>
          <text class="stat-label">处理中</text>
        </view>
        <view class="stat-item">
          <text class="stat-number">{{complaintStats.resolved}}</text>
          <text class="stat-label">已解决</text>
        </view>
      </view>
    </view>

    <!-- 投诉须知 -->
    <view class="notice-section">
      <view class="notice-card">
        <view class="notice-header">
          <image class="notice-icon" src="/static/icons/info.svg" mode="aspectFit"></image>
          <text class="notice-title">投诉须知</text>
        </view>
        <view class="notice-content">
          <text class="notice-text">• 请如实描述问题，提供准确信息</text>
          <text class="notice-text">• 可上传相关图片作为证据</text>
          <text class="notice-text">• 一般问题48小时内处理完成</text>
          <text class="notice-text">• 紧急问题将优先处理</text>
          <text class="notice-text">• 恶意投诉将承担相应责任</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>

  <!-- 浮动按钮 -->
  <view class="fab" bindtap="newComplaint">
    <image class="fab-icon" src="/static/icons/edit.svg" mode="aspectFit"></image>
  </view>
</view>
/* pages/owner/messages.wxss */
.messages-container {
  min-height: 100vh;
  background: #f8f9fa;
}

.page-header {
  background: linear-gradient(135deg, #5865f2 0%, #3c45a5 100%);
  padding: 60rpx 32rpx 40rpx;
  color: white;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.page-title {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 12rpx;
  letter-spacing: 0.5rpx;
}

.page-subtitle {
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.4;
}

.content {
  height: calc(100vh - 180rpx);
  padding: 32rpx;
  box-sizing: border-box;
}

/* 消息标签页 */
.message-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid #e9ecef;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.2s ease;
}

.tab-item.active {
  background: #5865f2;
}

.tab-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #6c757d;
}

.tab-item.active .tab-text {
  color: #ffffff;
}

.tab-badge {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  min-width: 20rpx;
  height: 20rpx;
  background: #dc3545;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: white;
  font-weight: 600;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.message-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  border: 1rpx solid #e9ecef;
  transition: all 0.2s ease;
  position: relative;
}

.message-item.unread {
  border-left: 6rpx solid #2d3748;
}

.message-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.message-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.icon-svg {
  width: 32rpx;
  height: 32rpx;
  filter: invert(1);
}

.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.message-title {
  color: #333333;
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-time {
  color: #adb5bd;
  font-size: 22rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.message-desc {
  color: #6c757d;
  font-size: 24rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.message-status {
  margin-left: 16rpx;
  display: flex;
  align-items: center;
}

.unread-dot {
  width: 12rpx;
  height: 12rpx;
  background: #dc3545;
  border-radius: 50%;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  color: #6c757d;
  font-size: 28rpx;
}

.bottom-placeholder {
  height: 40rpx;
}
/* 保安个人中心页面样式 */

/* 用户信息头部 */
.user-header {
  background: linear-gradient(135deg, #2d3748 0%, #4a5568 100%);
  padding: 48rpx 32rpx 32rpx;
  color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
}

.user-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 12rpx;
}

.work-status {
  margin-top: 16rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-on {
  background: rgba(56, 161, 105, 0.2);
  color: #68d391;
  border: 1rpx solid rgba(56, 161, 105, 0.3);
}

.status-off {
  background: rgba(108, 117, 125, 0.2);
  color: #a0aec0;
  border: 1rpx solid rgba(108, 117, 125, 0.3);
}

/* 业绩统计 */
.performance-stats {
  margin: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx 0 rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e9ecef;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-item {
  text-align: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #2d3748;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #6c757d;
}

/* 排班信息卡片 */
.schedule-info {
  margin: 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.view-more {
  font-size: 24rpx;
  color: #2d3748;
  opacity: 0.7;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  gap: 24rpx;
}

.schedule-item.today {
  background: rgba(45, 55, 72, 0.05);
  border: 1rpx solid rgba(45, 55, 72, 0.1);
}

.schedule-date {
  text-align: center;
  min-width: 80rpx;
}

.date-day {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  line-height: 1;
}

.date-text {
  font-size: 20rpx;
  color: #6c757d;
  margin-top: 4rpx;
}

.schedule-shift {
  flex: 1;
}

.shift-type {
  font-size: 26rpx;
  font-weight: 500;
  color: #2d3748;
  margin-bottom: 4rpx;
}

.shift-time {
  font-size: 22rpx;
  color: #6c757d;
}

.schedule-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-dot.completed {
  background: #38a169;
}

.status-dot.pending {
  background: #d69e2e;
}

.status-dot.rest {
  background: #6c757d;
}

.status-text {
  font-size: 22rpx;
  color: #6c757d;
}

/* 功能菜单 */
.menu-section {
  margin: 32rpx;
}

.menu-group {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx 0 rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e9ecef;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f1f3f5;
  transition: all 0.3s ease;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f9fa;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  position: relative;
}

.icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.7;
}

.logout-icon {
  filter: brightness(0) saturate(100%) invert(26%) sepia(85%) saturate(3102%) hue-rotate(336deg) brightness(85%) contrast(93%);
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #e53e3e;
  color: #ffffff;
  border-radius: 50%;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3748;
  margin-bottom: 6rpx;
}

.logout-text {
  color: #e53e3e;
}

.menu-desc {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.4;
}

.menu-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* 头像编辑相关样式 */
.avatar-container {
  position: relative;
  display: inline-block;
}

.avatar-edit-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: #2d3748;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx 0 rgba(0, 0, 0, 0.15);
}

.edit-icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}

.user-name-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.edit-name-btn {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(45, 55, 72, 0.1);
  border-radius: 50%;
  padding: 8rpx;
}

.edit-icon-small {
  width: 16rpx;
  height: 16rpx;
  opacity: 0.7;
}

.user-signature {
  font-size: 24rpx;
  color: #6c757d;
  margin-top: 8rpx;
  line-height: 1.4;
}

.user-signature.placeholder {
  color: #a0aec0;
  font-style: italic;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 40rpx 0 rgba(0, 0, 0, 0.15);
  transform: scale(0.9) translateY(40rpx);
  transition: all 0.3s ease;
  width: calc(100% - 64rpx);
  max-width: 600rpx;
}

.modal-overlay.show .modal-content {
  transform: scale(1) translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

/* 个人资料表单样式 */
.profile-form {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3748;
  margin-bottom: 16rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 24rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #495057;
  box-sizing: border-box;
}

.form-input:focus,
.form-textarea:focus {
  border-color: #2d3748;
  background: #ffffff;
}

.form-textarea {
  min-height: 120rpx;
  resize: none;
  line-height: 1.5;
}

.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 48rpx;
}

.form-btn {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border-radius: 12rpx;
  border: none;
}

.form-btn::after {
  border: none;
}

.btn-cancel {
  background: #f8f9fa;
  color: #6c757d;
  border: 1rpx solid #dee2e6;
}

.btn-submit {
  background: #2d3748;
  color: #ffffff;
}

.btn-submit:active {
  background: #1a202c;
}

.btn-cancel:active {
  background: #e9ecef;
}

/* 头像选择弹窗样式 */
.avatar-modal {
  max-width: 400rpx;
}

.avatar-options {
  padding: 32rpx;
}

.avatar-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: #f8f9fa;
  transition: all 0.2s ease;
}

.avatar-option:last-child {
  margin-bottom: 0;
}

.avatar-option:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.option-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2d3748;
  border-radius: 50%;
  margin-right: 24rpx;
}

.option-icon .icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}

.delete-icon {
  filter: brightness(0) saturate(100%) invert(27%) sepia(51%) saturate(2878%) hue-rotate(346deg) brightness(104%) contrast(97%);
}

.option-text {
  font-size: 28rpx;
  color: #2d3748;
  font-weight: 500;
}

.delete-text {
  color: #e53e3e;
}
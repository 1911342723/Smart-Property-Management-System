/* 保安门岗管理页面样式 */

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  margin: 32rpx;
  box-shadow: 0 4rpx 12rpx 0 rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e9ecef;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8f9fa;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  background: #2d3748;
  color: #ffffff;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
  filter: opacity(0.7);
}

.tab-item.active .tab-icon {
  filter: brightness(0) saturate(100%) invert(100%);
}

.tab-item text {
  font-size: 24rpx;
  font-weight: 500;
}

/* 标签页内容 */
.tab-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 扫码区域 */
.scan-section {
  margin: 32rpx;
  text-align: center;
}

.scan-header {
  margin-bottom: 48rpx;
}

.scan-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 12rpx;
}

.scan-desc {
  font-size: 26rpx;
  color: #6c757d;
  line-height: 1.5;
}

.scan-area {
  margin: 48rpx 0;
}

.scan-box {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
  background: #f8f9fa;
  border: 3rpx dashed #dee2e6;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.scan-box:active {
  background: #e9ecef;
  border-color: #adb5bd;
}

.scan-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.scan-text {
  font-size: 28rpx;
  color: #6c757d;
  font-weight: 500;
}

.scan-tips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 32rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #6c757d;
  text-align: left;
}

/* 访客信息卡片 */
.visitor-info {
  margin: 32rpx;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.info-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.status-valid {
  background: rgba(56, 161, 105, 0.1);
  color: #38a169;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-invalid {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.info-content {
  margin-bottom: 32rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.info-label {
  font-size: 26rpx;
  color: #6c757d;
  font-weight: 500;
  white-space: nowrap;
  margin-right: 16rpx;
}

.info-value {
  font-size: 26rpx;
  color: #2d3748;
  flex: 1;
  word-wrap: break-word;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-buttons .btn {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 车辆表单 */
.vehicle-form {
  margin: 32rpx;
}

.form-header {
  margin-bottom: 32rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 12rpx;
}

.form-desc {
  font-size: 26rpx;
  color: #6c757d;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3748;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #495057;
  box-sizing: border-box;
  line-height: 1.5;
  display: flex;
  align-items: center;
  min-height: 40rpx;
}

.form-input:focus {
  border-color: #2d3748;
  box-shadow: 0 0 0 4rpx rgba(45, 55, 72, 0.1);
}

.form-input::placeholder {
  line-height: 1.5;
  vertical-align: middle;
  color: #a0aec0;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #495057;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-textarea::placeholder {
  line-height: 1.5;
  vertical-align: middle;
  color: #a0aec0;
}

.picker {
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  padding: 24rpx;
  color: #495057;
  font-size: 28rpx;
}

.form-actions {
  margin-top: 48rpx;
}

.form-btn {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 记录列表 */
.visitor-records,
.vehicle-records {
  margin: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 24rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e9ecef;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.visitor-name,
.plate-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
}

.record-time {
  font-size: 24rpx;
  color: #6c757d;
}

.record-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.info-text {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.4;
}

.record-status {
  margin-left: 16rpx;
}

.status-entered {
  background: rgba(56, 161, 105, 0.1);
  color: #38a169;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-denied {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-left {
  background: rgba(108, 117, 125, 0.1);
  color: #6c757d;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-parked {
  background: rgba(32, 201, 151, 0.1);
  color: #20c997;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.record-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid #dee2e6;
  background: transparent;
  color: #6c757d;
}

.btn-small:active {
  background: #f8f9fa;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6c757d;
}

/* 联系业主弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 32rpx;
  max-width: 600rpx;
  width: 100%;
  box-shadow: 0 20rpx 40rpx 0 rgba(0, 0, 0, 0.15);
  transform: scale(0.9) translateY(40rpx);
  transition: all 0.3s ease;
}

.modal-overlay.show .modal-content {
  transform: scale(1) translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

.modal-body {
  padding: 32rpx;
}

.contact-info {
  margin-bottom: 32rpx;
}

.contact-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.contact-label {
  font-size: 26rpx;
  color: #6c757d;
  font-weight: 500;
  white-space: nowrap;
  margin-right: 16rpx;
}

.contact-value {
  font-size: 26rpx;
  color: #2d3748;
  font-weight: 500;
}

.contact-actions .btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  font-weight: 600;
}






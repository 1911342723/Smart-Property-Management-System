/* 历史巡检记录页面样式 */

/* 筛选栏 */
.filter-bar {
  background: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 2rpx 8rpx 0 rgba(0, 0, 0, 0.05);
  border-bottom: 1rpx solid #e9ecef;
}

.filter-item {
  flex: 1;
}

.date-picker,
.status-picker {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #495057;
}

.picker-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  opacity: 0.6;
}

.picker-arrow {
  width: 16rpx;
  height: 16rpx;
  margin-left: auto;
  opacity: 0.4;
}

/* 统计摘要 */
.stats-summary {
  margin: 24rpx 32rpx;
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-number {
  font-size: 40rpx;
  font-weight: bold;
  color: #2d3748;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #6c757d;
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background: #e9ecef;
  margin: 0 24rpx;
}

/* 巡检记录列表 */
.patrol-list {
  padding: 0 32rpx;
}

.patrol-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e9ecef;
}

.patrol-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.patrol-point {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
}

.patrol-date {
  font-size: 22rpx;
  color: #6c757d;
  background: #f8f9fa;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
}

.patrol-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.patrol-info {
  flex: 1;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: #6c757d;
  margin-right: 8rpx;
  white-space: nowrap;
}

.info-value {
  font-size: 24rpx;
  color: #495057;
}

.patrol-status {
  margin-left: 16rpx;
}

.status-badge {
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-normal {
  background: rgba(56, 161, 105, 0.1);
  color: #38a169;
}

.status-abnormal {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
}

.patrol-desc {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.5;
  margin-bottom: 12rpx;
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 8rpx;
}

.patrol-photos {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.photo-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.patrol-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f1f3f5;
}

.patrol-guard,
.patrol-duration {
  font-size: 22rpx;
  color: #6c757d;
}

/* 加载状态 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 16rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e9ecef;
  border-top: 3rpx solid #2d3748;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #6c757d;
}

.no-more {
  text-align: center;
  padding: 48rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #adb5bd;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6c757d;
  margin-bottom: 12rpx;
  display: block;
}

.empty-desc {
  font-size: 24rpx;
  color: #adb5bd;
  display: block;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 40rpx 0 rgba(0, 0, 0, 0.15);
  transform: scale(0.9) translateY(40rpx);
  transition: all 0.3s ease;
  width: calc(100% - 64rpx);
}

.modal-overlay.show .modal-content {
  transform: scale(1) translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

.modal-body {
  padding: 32rpx;
}

.detail-section {
  margin-bottom: 32rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 16rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.detail-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-item {
  display: flex;
  align-items: flex-start;
}

.detail-label {
  font-size: 26rpx;
  color: #6c757d;
  font-weight: 500;
  margin-right: 16rpx;
  white-space: nowrap;
  min-width: 120rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #2d3748;
  flex: 1;
  word-wrap: break-word;
}

.detail-desc {
  font-size: 26rpx;
  color: #495057;
  line-height: 1.6;
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
}

.detail-photos {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.detail-photo {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8rpx;
  object-fit: cover;
}

.detail-gps {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.gps-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.gps-label {
  font-size: 24rpx;
  color: #6c757d;
}

.gps-value {
  font-size: 24rpx;
  color: #495057;
  font-family: monospace;
}











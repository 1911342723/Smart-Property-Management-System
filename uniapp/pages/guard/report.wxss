/* 保安异常上报页面样式 */

/* 快速上报类型选择 */
.report-types {
  margin: 32rpx;
}

.types-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 24rpx;
}

.types-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background: #ffffff;
  border: 2rpx solid #e9ecef;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.type-item.active {
  background: #fff5f5;
  border-color: #e53e3e;
  color: #e53e3e;
}

.type-item:active {
  transform: scale(0.98);
  background: #f8f9fa;
}

.type-item.active:active {
  background: #fed7d7;
}

.type-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
  opacity: 0.7;
}

.type-item.active .type-icon {
  filter: brightness(0) saturate(100%) invert(15%) sepia(86%) saturate(3102%) hue-rotate(336deg) brightness(85%) contrast(93%);
  opacity: 1;
}

.type-text {
  font-size: 24rpx;
  font-weight: 500;
  text-align: center;
  line-height: 1.4;
}

/* 上报表单 */
.report-form {
  margin: 32rpx;
}

.form-header {
  margin-bottom: 32rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 12rpx;
}

.form-desc {
  font-size: 26rpx;
  color: #6c757d;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3748;
  margin-bottom: 16rpx;
}

.selected-type {
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  padding: 24rpx;
}

.type-name {
  font-size: 28rpx;
  color: #495057;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #495057;
  box-sizing: border-box;
  line-height: 1.5;
  display: flex;
  align-items: center;
  min-height: 40rpx;
}

.form-input:focus {
  border-color: #e53e3e;
  box-shadow: 0 0 0 4rpx rgba(229, 62, 62, 0.1);
}

.form-input::placeholder {
  line-height: 1.5;
  vertical-align: middle;
  color: #a0aec0;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #495057;
  box-sizing: border-box;
  resize: none;
  line-height: 1.5;
}

.form-textarea::placeholder {
  line-height: 1.5;
  vertical-align: middle;
  color: #a0aec0;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #adb5bd;
  margin-top: 8rpx;
}

/* 紧急程度选择 */
.urgency-options {
  display: flex;
  gap: 16rpx;
}

.urgency-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 16rpx;
  background: #f8f9fa;
  border: 2rpx solid #dee2e6;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  font-size: 26rpx;
}

.urgency-item.active {
  background: #fff;
  border-color: currentColor;
}

.urgency-item.active.low {
  color: #38a169;
  background: rgba(56, 161, 105, 0.05);
}

.urgency-item.active.medium {
  color: #d69e2e;
  background: rgba(214, 158, 46, 0.05);
}

.urgency-item.active.high {
  color: #e53e3e;
  background: rgba(229, 62, 62, 0.05);
}

.urgency-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.urgency-dot.low {
  background: #38a169;
}

.urgency-dot.medium {
  background: #d69e2e;
}

.urgency-dot.high {
  background: #e53e3e;
}

/* 照片上传 */
.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.photo-preview {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  object-fit: cover;
}

.photo-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #e53e3e;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  width: 16rpx;
  height: 16rpx;
  filter: brightness(0) saturate(100%) invert(100%);
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  background: #f8f9fa;
  border: 2rpx dashed #dee2e6;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.add-icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.6;
}

.add-text {
  font-size: 24rpx;
  color: #6c757d;
}

/* 语音录制 */
.voice-record {
  background: #f8f9fa;
  border: 1rpx solid #dee2e6;
  border-radius: 12rpx;
  padding: 24rpx;
}

.voice-list {
  margin-bottom: 24rpx;
}

.voice-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e9ecef;
}

.voice-item:last-child {
  border-bottom: none;
}

.voice-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.voice-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.voice-duration {
  font-size: 26rpx;
  color: #6c757d;
}

.voice-actions {
  display: flex;
  gap: 16rpx;
}

.voice-btn {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  border-radius: 6rpx;
  border: 1rpx solid #dee2e6;
  background: #ffffff;
  color: #6c757d;
}

.voice-btn.play {
  color: #38a169;
  border-color: #38a169;
}

.voice-btn.delete {
  color: #e53e3e;
  border-color: #e53e3e;
}

.record-controls {
  text-align: center;
}

.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 32rpx;
  background: #ffffff;
  border: 2rpx dashed #dee2e6;
  border-radius: 16rpx;
  color: #6c757d;
  transition: all 0.3s ease;
  width: 100%;
  box-sizing: border-box;
}

.record-btn.recording {
  background: #fed7d7;
  border-color: #e53e3e;
  color: #e53e3e;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.record-icon {
  width: 48rpx;
  height: 48rpx;
}

.record-btn text {
  font-size: 26rpx;
  font-weight: 500;
}

/* 表单按钮 */
.form-actions {
  margin-top: 48rpx;
}

.form-btn {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 上报记录 */
.report-records {
  margin: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 24rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e9ecef;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-type {
  display: flex;
  align-items: center;
}

.type-badge {
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.type-badge.type-security {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
}

.type-badge.type-fire {
  background: rgba(255, 69, 0, 0.1);
  color: #ff4500;
}

.type-badge.type-facility {
  background: rgba(214, 158, 46, 0.1);
  color: #d69e2e;
}

.type-badge.type-dispute {
  background: rgba(139, 69, 19, 0.1);
  color: #8b4513;
}

.type-badge.type-environment {
  background: rgba(32, 201, 151, 0.1);
  color: #20c997;
}

.type-badge.type-other {
  background: rgba(108, 117, 125, 0.1);
  color: #6c757d;
}

.record-time {
  font-size: 24rpx;
  color: #6c757d;
}

.record-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-location {
  font-size: 26rpx;
  color: #495057;
  font-weight: 500;
}

.record-status {
  margin-left: 16rpx;
}

.status-badge {
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.status-badge.status-pending {
  background: rgba(214, 158, 46, 0.1);
  color: #d69e2e;
}

.status-badge.status-processing {
  background: rgba(32, 201, 151, 0.1);
  color: #20c997;
}

.status-badge.status-completed {
  background: rgba(56, 161, 105, 0.1);
  color: #38a169;
}

.record-desc {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-urgency {
  display: flex;
  justify-content: flex-end;
}

.urgency-badge {
  padding: 4rpx 8rpx;
  border-radius: 12rpx;
  font-size: 18rpx;
  font-weight: 500;
}

.urgency-badge.urgency-low {
  background: rgba(56, 161, 105, 0.1);
  color: #38a169;
}

.urgency-badge.urgency-medium {
  background: rgba(214, 158, 46, 0.1);
  color: #d69e2e;
}

.urgency-badge.urgency-high {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6c757d;
}

/* 历史记录入口 */
.history-entry {
  margin: 32rpx;
}

.entry-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  border: 1rpx solid #e9ecef;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.entry-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.7;
}

.entry-content {
  flex: 1;
}

.entry-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 8rpx;
}

.entry-desc {
  font-size: 24rpx;
  color: #6c757d;
}

.entry-arrow {
  width: 32rpx;
  height: 32rpx;
}

.arrow-icon {
  width: 100%;
  height: 100%;
  opacity: 0.5;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 40rpx 0 rgba(0, 0, 0, 0.15);
  transform: scale(0.9) translateY(40rpx);
  transition: all 0.3s ease;
}

.modal-overlay.show .modal-content {
  transform: scale(1) translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

.modal-body {
  padding: 32rpx;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.detail-label {
  font-size: 26rpx;
  color: #6c757d;
  font-weight: 500;
  margin-right: 16rpx;
  white-space: nowrap;
}

.detail-value {
  font-size: 26rpx;
  color: #2d3748;
  flex: 1;
  word-wrap: break-word;
}

.detail-photos {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  width: 100%;
  margin-top: 12rpx;
}

.detail-photo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  object-fit: cover;
}






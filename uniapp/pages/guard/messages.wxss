/* 消息通知页面样式 */

/* 消息类型切换 */
.message-tabs {
  background: #ffffff;
  display: flex;
  padding: 0 32rpx;
  box-shadow: 0 2rpx 8rpx 0 rgba(0, 0, 0, 0.05);
  border-bottom: 1rpx solid #e9ecef;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #2d3748;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2d3748;
  border-radius: 2rpx;
}

.tab-item text {
  font-size: 26rpx;
  color: #6c757d;
  font-weight: 500;
}

.tab-item.active text {
  color: #2d3748;
  font-weight: 600;
}

.tab-badge {
  position: absolute;
  top: 12rpx;
  right: 8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #e53e3e;
  color: #ffffff;
  border-radius: 50%;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #f8f9fa;
  border-bottom: 1rpx solid #e9ecef;
}

.action-btn {
  padding: 12rpx 24rpx;
  background: #2d3748;
  color: #ffffff;
  border: none;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn[disabled] {
  opacity: 0.6;
}

.message-count {
  font-size: 24rpx;
  color: #6c757d;
}

/* 消息列表 */
.message-list {
  padding: 0 32rpx;
}

.message-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e9ecef;
  position: relative;
  transition: all 0.3s ease;
}

.message-item.unread {
  background: rgba(45, 55, 72, 0.02);
  border-left: 4rpx solid #2d3748;
}

.message-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx 0 rgba(0, 0, 0, 0.1);
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.message-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.type-icon.type-system {
  background: rgba(32, 201, 151, 0.1);
}

.type-icon.type-work {
  background: rgba(45, 55, 72, 0.1);
}

.type-icon.type-notice {
  background: rgba(214, 158, 46, 0.1);
}

.type-icon .icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.7;
}

.type-text {
  font-size: 22rpx;
  color: #6c757d;
  font-weight: 500;
}

.message-time {
  font-size: 22rpx;
  color: #adb5bd;
}

.message-content {
  margin-bottom: 16rpx;
}

.message-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.message-preview {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.message-footer {
  border-top: 1rpx solid #f1f3f5;
  padding-top: 16rpx;
}

.message-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-attachment {
  background: rgba(32, 201, 151, 0.1);
  color: #20c997;
}

.tag-urgent {
  background: rgba(229, 62, 62, 0.1);
  color: #e53e3e;
}

.tag-action {
  background: rgba(214, 158, 46, 0.1);
  color: #d69e2e;
}

.tag-icon {
  width: 16rpx;
  height: 16rpx;
}

.unread-indicator {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  background: #e53e3e;
  border-radius: 50%;
}

/* 加载状态 */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  gap: 16rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e9ecef;
  border-top: 3rpx solid #2d3748;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #6c757d;
}

.no-more {
  text-align: center;
  padding: 48rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #adb5bd;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 32rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6c757d;
  margin-bottom: 12rpx;
  display: block;
}

.empty-desc {
  font-size: 24rpx;
  color: #adb5bd;
  display: block;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 40rpx 0 rgba(0, 0, 0, 0.15);
  transform: scale(0.9) translateY(40rpx);
  transition: all 0.3s ease;
  width: calc(100% - 64rpx);
}

.modal-overlay.show .modal-content {
  transform: scale(1) translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

.modal-body {
  padding: 32rpx;
}

.message-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.detail-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.type-name {
  font-size: 24rpx;
  color: #6c757d;
  font-weight: 500;
}

.detail-time {
  font-size: 22rpx;
  color: #adb5bd;
}

.message-detail-content {
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.detail-content {
  font-size: 26rpx;
  color: #495057;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.detail-attachments {
  margin-bottom: 24rpx;
}

.attachments-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 16rpx;
}

.attachment-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  gap: 12rpx;
}

.attachment-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.attachment-name {
  flex: 1;
  font-size: 24rpx;
  color: #495057;
}

.download-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.5;
}

.detail-actions {
  margin-bottom: 24rpx;
}

.actions-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 16rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.action-buttons .btn {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.message-detail-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #e9ecef;
}

.detail-sender {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sender-label {
  font-size: 22rpx;
  color: #6c757d;
}

.sender-name {
  font-size: 22rpx;
  color: #495057;
  font-weight: 500;
}

.detail-read-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.read-label {
  font-size: 22rpx;
  color: #6c757d;
}

.read-time {
  font-size: 22rpx;
  color: #adb5bd;
}











/* 个人资料编辑页面样式 */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 头像编辑区域 */
.avatar-section {
  background: #ffffff;
  padding: 60rpx 32rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.avatar-container {
  position: relative;
  display: inline-block;
}

.user-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: 0 8rpx 24rpx 0 rgba(0, 0, 0, 0.1);
}

.avatar-edit-overlay {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: #ffffff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
}

.camera-icon {
  width: 20rpx;
  height: 20rpx;
  filter: brightness(0) invert(1);
}

.edit-text {
  font-size: 22rpx;
  color: #ffffff;
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  margin-bottom: 32rpx;
}

.form-item {
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3748;
  margin-bottom: 20rpx;
  display: block;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 20rpx 0;
  background: transparent;
  border: none;
  font-size: 28rpx;
  color: #2d3748;
  line-height: 1.5;
  box-sizing: border-box;
  min-height: 40rpx;
}

.form-input {
  display: flex;
  align-items: center;
}

.form-input::placeholder,
.form-textarea::placeholder {
  color: #a0aec0;
  font-size: 28rpx;
  line-height: 1.5;
  vertical-align: middle;
}

.form-textarea {
  min-height: 120rpx;
  resize: none;
}

/* 保存按钮 */
.save-section {
  padding: 32rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: #2d3748;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  background: #1a202c;
}

.save-btn:disabled {
  background: #a0aec0;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.modal-overlay.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 32rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 40rpx 0 rgba(0, 0, 0, 0.15);
  transform: scale(0.9) translateY(40rpx);
  transition: all 0.3s ease;
  width: calc(100% - 64rpx);
  max-width: 400rpx;
}

.modal-overlay.show .modal-content {
  transform: scale(1) translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3748;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

/* 头像选择选项 */
.avatar-options {
  padding: 32rpx;
}

.avatar-option {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: #f8f9fa;
  transition: all 0.2s ease;
}

.avatar-option:last-child {
  margin-bottom: 0;
}

.avatar-option:active {
  background: #e9ecef;
  transform: scale(0.98);
}

.option-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2d3748;
  border-radius: 50%;
  margin-right: 24rpx;
}

.option-icon .icon {
  width: 24rpx;
  height: 24rpx;
  filter: brightness(0) invert(1);
}

.delete-icon {
  filter: brightness(0) saturate(100%) invert(27%) sepia(51%) saturate(2878%) hue-rotate(346deg) brightness(104%) contrast(97%);
}

.option-text {
  font-size: 28rpx;
  color: #2d3748;
  font-weight: 500;
}

.delete-text {
  color: #e53e3e;
}

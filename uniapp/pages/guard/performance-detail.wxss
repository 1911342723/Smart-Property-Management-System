/* 业绩统计详情页面样式 */

/* 时间筛选 */
.time-filter {
  background: #ffffff;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.filter-tabs {
  display: flex;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 6rpx;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #6c757d;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.filter-tab.active {
  background: #2d3748;
  color: #ffffff;
}

/* 核心指标 */
.metrics-overview {
  margin: 24rpx 32rpx;
  padding: 32rpx 24rpx;
}

.metrics-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 24rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.metric-item {
  text-align: center;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  position: relative;
}

.metric-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2d3748;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.metric-label {
  font-size: 22rpx;
  color: #6c757d;
  margin-bottom: 12rpx;
}

.metric-trend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.metric-trend.trend-up {
  color: #38a169;
}

.metric-trend.trend-down {
  color: #e53e3e;
}

.trend-icon {
  width: 16rpx;
  height: 16rpx;
}

/* 排名区域 */
.ranking-section {
  margin: 24rpx 32rpx;
  padding: 32rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
}

.ranking-desc {
  font-size: 22rpx;
  color: #6c757d;
}

.ranking-display {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.rank-number {
  font-size: 72rpx;
  font-weight: bold;
  color: #2d3748;
  line-height: 1;
}

.rank-info {
  flex: 1;
}

.rank-text {
  font-size: 24rpx;
  color: #6c757d;
  display: block;
  margin-bottom: 8rpx;
}

.rank-change {
  font-size: 22rpx;
  font-weight: 500;
}

.rank-up {
  color: #38a169;
}

.rank-down {
  color: #e53e3e;
}

/* 工作明细 */
.work-details {
  margin: 24rpx 32rpx;
  padding: 32rpx 24rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.detail-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.detail-icon .icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.detail-content {
  flex: 1;
}

.detail-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 12rpx;
}

.detail-stats {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #6c757d;
  line-height: 1.4;
}

/* 趋势图表 */
.trend-chart {
  margin: 24rpx 32rpx;
  padding: 32rpx 24rpx;
}

.chart-placeholder {
  height: 300rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #dee2e6;
}

.chart-note {
  font-size: 24rpx;
  color: #adb5bd;
}











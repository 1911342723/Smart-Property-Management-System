/* 设置页面样式 */

/* 个人信息区域 */
.profile-section {
  margin: 32rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
}

.profile-item,
.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f3f5;
}

.profile-item:last-child,
.setting-item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 64rpx;
  height: 64rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.7;
}

.item-content,
.item-info {
  flex: 1;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2d3748;
  margin-bottom: 6rpx;
}

.item-desc {
  font-size: 24rpx;
  color: #6c757d;
  line-height: 1.4;
}

.item-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

/* 设置区域 */
.settings-section {
  margin: 32rpx;
}

.setting-item {
  justify-content: space-between;
}

/* 退出登录 */
.logout-section {
  padding: 48rpx 32rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #e53e3e;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  opacity: 0.9;
  transform: translateY(2rpx);
}











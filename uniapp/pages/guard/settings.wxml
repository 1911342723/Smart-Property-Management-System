<!--设置页面-->
<view class="page-container">
  <!-- 个人信息 -->
  <view class="profile-section card">
    <view class="section-header">
      <text class="section-title">个人信息</text>
    </view>
    <view class="profile-item" bindtap="editProfile">
      <view class="item-icon">
        <image src="/static/icons/user.svg" class="icon"></image>
      </view>
      <view class="item-content">
        <view class="item-title">个人资料</view>
        <view class="item-desc">编辑姓名、头像等信息</view>
      </view>
      <image src="/static/icons/arrow-right.svg" class="item-arrow"></image>
    </view>
  </view>

  <!-- 通知设置 -->
  <view class="settings-section card">
    <view class="section-header">
      <text class="section-title">通知设置</text>
    </view>
    <view class="setting-item">
      <view class="item-info">
        <text class="item-title">系统通知</text>
        <text class="item-desc">接收系统重要通知</text>
      </view>
      <switch checked="{{settings.systemNotification}}" bindchange="toggleSetting" data-key="systemNotification" />
    </view>
    <view class="setting-item">
      <view class="item-info">
        <text class="item-title">工作提醒</text>
        <text class="item-desc">接收排班和任务提醒</text>
      </view>
      <switch checked="{{settings.workReminder}}" bindchange="toggleSetting" data-key="workReminder" />
    </view>
  </view>

  <!-- 功能设置 -->
  <view class="settings-section card">
    <view class="section-header">
      <text class="section-title">功能设置</text>
    </view>
    <view class="setting-item" bindtap="clearCache">
      <view class="item-info">
        <text class="item-title">清理缓存</text>
        <text class="item-desc">清理应用缓存数据</text>
      </view>
      <image src="/static/icons/arrow-right.svg" class="item-arrow"></image>
    </view>
    <view class="setting-item" bindtap="checkUpdate">
      <view class="item-info">
        <text class="item-title">检查更新</text>
        <text class="item-desc">当前版本 v1.0.0</text>
      </view>
      <image src="/static/icons/arrow-right.svg" class="item-arrow"></image>
    </view>
  </view>

  <!-- 其他 -->
  <view class="settings-section card">
    <view class="section-header">
      <text class="section-title">其他</text>
    </view>
    <view class="setting-item" bindtap="showAbout">
      <view class="item-info">
        <text class="item-title">关于我们</text>
        <text class="item-desc">版本信息和服务条款</text>
      </view>
      <image src="/static/icons/arrow-right.svg" class="item-arrow"></image>
    </view>
    <view class="setting-item" bindtap="contactSupport">
      <view class="item-info">
        <text class="item-title">意见反馈</text>
        <text class="item-desc">联系技术支持</text>
      </view>
      <image src="/static/icons/arrow-right.svg" class="item-arrow"></image>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>











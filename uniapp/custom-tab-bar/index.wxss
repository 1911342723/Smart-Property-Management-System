/* custom-tab-bar/index.wxss */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #ffffff;
  border-top: 1rpx solid #e9ecef;
  display: flex;
  z-index: 1000;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: content-box;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
  transition: all 0.2s ease;
}

.tab-bar-item:active {
  background: rgba(255, 255, 255, 0.05);
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

.icon-svg {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.6;
  transition: all 0.2s ease;
}

.icon-svg.selected {
  opacity: 1;
  transform: scale(1.1);
}

.tab-bar-text {
  font-size: 20rpx;
  color: #adb5bd;
  transition: all 0.2s ease;
  font-weight: 400;
}

.tab-bar-text.selected {
  color: #2d3748;
  font-weight: 500;
}

.tab-bar-item.selected {
  transform: translateY(-2rpx);
}

/* 适配不同设备 */
@media screen and (max-width: 320px) {
  .tab-bar {
    height: 90rpx;
  }
  
  .icon-text {
    font-size: 36rpx;
  }
  
  .tab-bar-text {
    font-size: 18rpx;
  }
}

/* 适配刘海屏 */
.tab-bar {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
